@inherits UmbracoViewPage<Clean.Core.Models.ViewModels.PageHeaderViewModel>

@{
    string heroImageUrl = Model.HasBackgroundImage
        ? Model.BackgroundImage.GetCropUrl(1600, 900)
        : "/media/f01jqvmq/2.jpg";
    var pageTitle = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title : Model.Name;
}

<div class="content-wrapper">
    <header class="ltu-page-hero @(Model.IsArticle ? "ltu-page-hero--article" : string.Empty)">
        <div class="ltu-page-hero__content">
            <p class="ltu-page-hero__eyebrow">@(Model.IsArticle ? "Featured Insight" : "Laser Therapy University")</p>
            <h1 class="ltu-page-hero__title">@pageTitle</h1>

            @if (Model.HasSubtitle)
            {
                <p class="ltu-page-hero__subtitle">@Model.Subtitle</p>
            }

            @if (Model.IsArticle)
            {
                <div class="ltu-page-hero__meta">
                    @if (Model.HasAuthor)
                    {
                        <span>By @Model.AuthorName</span>
                    }
                    @if (Model.ArticleDate.HasValue)
                    {
                        <span>@Model.ArticleDate.Value.ToString("MMMM dd, yyyy")</span>
                    }
                </div>

                @if (Model.Categories != null && Model.Categories.Any())
                {
                    <div class="ltu-page-hero__tags">
                        @foreach (var category in Model.Categories.Select(x => x.Name).OrderBy(x => x))
                        {
                            <span class="ltu-page-hero__tag">@category</span>
                        }
                    </div>
                }
            }
        </div>

        <div class="ltu-page-hero__media">
            <img src="@heroImageUrl" alt="@pageTitle" />
        </div>
    </header>
</div>
