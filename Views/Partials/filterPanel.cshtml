@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Cms.Web.Common
@inject IUmbracoHelperAccessor UmbracoHelperAccessor
@model (IEnumerable<IPublishedContent> Items, int Total, string ItemSelector)
@{
    var items = Model.Items?.ToList() ?? new List<IPublishedContent>();
    var total = Model.Total;
    var itemSelector = Model.ItemSelector;

    UmbracoHelperAccessor.TryGetUmbracoHelper(out var umbracoHelper);

    var filtersRoot = umbracoHelper?.ContentAtRoot()
        .DescendantsOrSelfOfType("filterRoot")
        .FirstOrDefault();

    var usedTagKeys = new HashSet<Guid>();
    foreach (var item in items)
    {
        var tags = item.Value<IEnumerable<IPublishedContent>>("tags");
        if (tags == null)
        {
            continue;
        }

        foreach (var tag in tags.Where(t => t != null))
        {
            usedTagKeys.Add(tag.Key);
        }
    }

    var filterSections = new List<dynamic>();
    if (filtersRoot != null)
    {
        var sections = filtersRoot.Children().Where(s => s.ContentType.Alias == "filterSection" && s.IsPublished()).OrderBy(s => s.SortOrder).ToList();
        foreach (var section in sections)
        {
            var categories = new List<dynamic>();
            var sectionCategories = section.Children().Where(c => c.ContentType.Alias == "filterCategory" && c.IsPublished()).OrderBy(c => c.SortOrder).ToList();
            foreach (var category in sectionCategories)
            {
                var categoryTags = category.Children()
                    .Where(t => t.ContentType.Alias == "filterTag" && t.IsPublished())
                    .OrderBy(t => t.SortOrder)
                    .Select(t => new
                    {
                        Key = t.Key,
                        Name = t.Value<string>("tagName") ?? t.Name,
                        IsUsed = usedTagKeys.Contains(t.Key)
                    })
                    .ToList();

                if (categoryTags.Any())
                {
                    categories.Add(new
                    {
                        Key = category.Key,
                        Title = category.Value<string>("categoryTitle") ?? category.Name,
                        Tags = categoryTags
                    });
                }
            }

            if (categories.Any())
            {
                filterSections.Add(new
                {
                    Key = section.Key,
                    Title = section.Value<string>("sectionTitle") ?? section.Name,
                    Categories = categories
                });
            }
        }
    }
}

@if (filterSections.Any())
{
    <div class="filterWrap" id="filter-wrap">
        <div class="searchTopBanner">
            <div class="inner">
                <h2>Advanced Filters</h2>
                <span class="totalResults">@total</span>
                <h3>Results</h3>
                <div class="filterReset">
                    <a href="#" title="Reset Filter" id="resetFilter">Reset Filter</a>
                </div>
            </div>
        </div>

        <div class="instructions">
            <p>Open a filter group, select the tags you need, and the resource list below will update immediately.</p>
        </div>

        <div class="accordionWrap">
            @foreach (var filterSection in filterSections)
            {
                <div class="accordionPanel" data-id="@filterSection.Key">
                    <button type="button" class="accordionHeader" aria-expanded="false">
                        <span class="accordionTitle">@filterSection.Title</span>
                        <span class="accordionToggle">+</span>
                    </button>
                    <div class="accordionContent" hidden>
                        <div class="filterCategoriesGrid">
                            @foreach (var category in filterSection.Categories)
                            {
                                <div class="filterType" data-id="@category.Key">
                                    <h3>@category.Title</h3>
                                    <div class="filter-tags-container">
                                        @foreach (var tag in category.Tags)
                                        {
                                            <div class="filter-tag-item">
                                                @if (tag.IsUsed)
                                                {
                                                    <label>
                                                        <input id="filter_@tag.Key.ToString("N")" type="checkbox" name="filter" value="@tag.Key" class="filter-checkbox" />
                                                        <span>@tag.Name</span>
                                                    </label>
                                                }
                                                else
                                                {
                                                    <label class="aspNetDisabled disabled">
                                                        <input id="filter_@tag.Key.ToString("N")" type="checkbox" name="filter" disabled="disabled" />
                                                        <span>@tag.Name</span>
                                                    </label>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var selectedFilters = new Set();
            var allItems = [];
            var filteredItems = [];
            var filterCheckboxes = document.querySelectorAll('.filter-checkbox');
            var listItems = document.querySelectorAll('.@(itemSelector)');
            var totalResultsElement = document.querySelector('.totalResults');
            var resetButton = document.getElementById('resetFilter');
            var accordionHeaders = document.querySelectorAll('.accordionHeader');

            listItems.forEach(function (item) {
                var tags = item.dataset.tags ? item.dataset.tags.split(',').filter(function (t) { return t.trim(); }) : [];
                allItems.push({ element: item, tagSet: new Set(tags) });
            });

            filteredItems = allItems.slice();

            function updateResultCount() {
                if (totalResultsElement) {
                    totalResultsElement.textContent = filteredItems.length.toString();
                }
            }

            function highlightSelectedTags() {
                document.querySelectorAll('.theTags span[data-tag-key].highlight').forEach(function (el) {
                    el.classList.remove('highlight');
                });

                selectedFilters.forEach(function (filterKey) {
                    document.querySelectorAll('.theTags span[data-tag-key="' + filterKey + '"]').forEach(function (span) {
                        span.classList.add('highlight');
                    });
                });
            }

            function applyFilters() {
                if (selectedFilters.size === 0) {
                    filteredItems = allItems.slice();
                    allItems.forEach(function (item) { item.element.style.display = ''; });
                } else {
                    filteredItems = allItems.filter(function (item) {
                        for (var filterKey of selectedFilters) {
                            if (!item.tagSet.has(filterKey)) {
                                return false;
                            }
                        }
                        return true;
                    });

                    allItems.forEach(function (item) {
                        item.element.style.display = filteredItems.indexOf(item) >= 0 ? '' : 'none';
                    });
                }

                updateResultCount();
                highlightSelectedTags();
            }

            filterCheckboxes.forEach(function (checkbox) {
                checkbox.addEventListener('change', function () {
                    if (checkbox.checked) {
                        selectedFilters.add(checkbox.value);
                    } else {
                        selectedFilters.delete(checkbox.value);
                    }

                    applyFilters();
                });
            });

            accordionHeaders.forEach(function (header) {
                header.addEventListener('click', function () {
                    var panel = header.closest('.accordionPanel');
                    var content = panel ? panel.querySelector('.accordionContent') : null;
                    var toggle = panel ? panel.querySelector('.accordionToggle') : null;
                    if (!panel || !content || !toggle) {
                        return;
                    }

                    var isHidden = content.hasAttribute('hidden');
                    if (isHidden) {
                        content.removeAttribute('hidden');
                        panel.classList.add('is-open');
                        header.setAttribute('aria-expanded', 'true');
                        toggle.textContent = '-';
                    } else {
                        content.setAttribute('hidden', 'hidden');
                        panel.classList.remove('is-open');
                        header.setAttribute('aria-expanded', 'false');
                        toggle.textContent = '+';
                    }
                });
            });

            if (resetButton) {
                resetButton.addEventListener('click', function (event) {
                    event.preventDefault();
                    filterCheckboxes.forEach(function (checkbox) { checkbox.checked = false; });
                    selectedFilters.clear();
                    applyFilters();
                });
            }

            updateResultCount();
        });
    </script>
}
