@model LTU_U15.Models.Membership.RegisterMemberViewModel
@{
    var serverMessage = TempData["MembershipMessage"] as string;
    var hasServerError = !string.IsNullOrWhiteSpace(serverMessage);
    var highlightEmail = hasServerError && serverMessage!.Contains("Email", StringComparison.OrdinalIgnoreCase);
    var highlightUsername = hasServerError && serverMessage!.Contains("Username", StringComparison.OrdinalIgnoreCase);
    var highlightPassword = hasServerError && serverMessage!.Contains("Password", StringComparison.OrdinalIgnoreCase);
}

<section class="ltu-auth-shell ltu-auth-shell--split">
    <form method="post" action="/account/registration" class="ltu-auth-card ltu-auth-form" id="membershipRegisterForm" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />

        <p class="ltu-auth-eyebrow">Member Registration</p>
        <h2 class="ltu-auth-title">Create your LTU account</h2>
        <p class="ltu-auth-copy">Register now to purchase paid content, reopen your learning library, and keep account activity attached to your member profile. Fields marked with an asterisk (*) are required.</p>

        @if (hasServerError)
        {
            <div class="membership-alert membership-alert-error membership-alert-animated membership-message" role="alert">@serverMessage</div>
        }
        <div id="registerErrorSummary" class="membership-alert membership-alert-error membership-alert-animated register-errors" style="display:none;"></div>

        <div class="ltu-auth-grid ltu-auth-grid--two" style="margin-top:18px;">
            <div class="ltu-auth-field ltu-auth-field--full">
                <label class="ltu-auth-label" asp-for="CustomerType">I am a*</label>
                <select class="ltu-auth-select" asp-for="CustomerType" id="CustomerType" data-required="true">
                    <option value="">Select</option>
                    <option value="laseru\Consumer">Consumer</option>
                    <option value="laseru\Professional">Medical Professional</option>
                    <option value="laseru\Educator Student">Educator/Student</option>
                </select>
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="FirstName">First Name*</label>
                <input class="ltu-auth-input" asp-for="FirstName" data-required="true" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="LastName">Last Name*</label>
                <input class="ltu-auth-input" asp-for="LastName" data-required="true" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="Email">Email Address*</label>
                <input class="ltu-auth-input @(highlightEmail ? "membership-invalid" : null)" asp-for="Email" data-required="true" autocomplete="email" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="PhoneNumber">Phone Number*</label>
                <input class="ltu-auth-input" asp-for="PhoneNumber" data-required="true" />
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <label class="ltu-auth-label" asp-for="CompanyName">Company Name / Practice Name</label>
                <input class="ltu-auth-input" asp-for="CompanyName" />
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <label class="ltu-auth-label" asp-for="Address">Address*</label>
                <input class="ltu-auth-input" asp-for="Address" data-required="true" />
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <label class="ltu-auth-label" asp-for="Address2">Address 2</label>
                <input class="ltu-auth-input" asp-for="Address2" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="City">City*</label>
                <input class="ltu-auth-input" asp-for="City" data-required="true" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="Country">Country*</label>
                <select class="ltu-auth-select" asp-for="Country" id="Country" data-required="true">
                    <option value="">Select Country</option>
                    <option value="United States">United States</option>
                    <option value="Canada">Canada</option>
                    <option value="United Kingdom">United Kingdom</option>
                    <option value="Australia">Australia</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="ltu-auth-field" id="stateWrap" style="display:none;">
                <label class="ltu-auth-label" asp-for="State">State</label>
                <select class="ltu-auth-select" asp-for="State">
                    <option value="">Select State</option>
                    <option value="AL">Alabama</option>
                    <option value="AK">Alaska</option>
                    <option value="AZ">Arizona</option>
                    <option value="AR">Arkansas</option>
                    <option value="CA">California</option>
                    <option value="CO">Colorado</option>
                    <option value="FL">Florida</option>
                    <option value="GA">Georgia</option>
                    <option value="IL">Illinois</option>
                    <option value="NY">New York</option>
                    <option value="TX">Texas</option>
                    <option value="WA">Washington</option>
                </select>
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="ZipPostalCode">Zip/Postal Code*</label>
                <input class="ltu-auth-input" asp-for="ZipPostalCode" data-required="true" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="UserType">User Type*</label>
                <select class="ltu-auth-select" asp-for="UserType" id="UserType" data-required="true">
                    <option value="">Select</option>
                    <option value="Prospective Customer">Prospective Customer</option>
                    <option value="Laser Product Owner">Laser Product Owner</option>
                </select>
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="ProductOwned">Product Owned*</label>
                <select class="ltu-auth-select" asp-for="ProductOwned" id="ProductOwned" data-required="true">
                    <option value="">Select</option>
                    <option value="GameDay Laser">GameDay Laser</option>
                    <option value="PainAway Laser">PainAway Laser</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="ltu-auth-field ltu-auth-field--full" id="productNameWrap" style="display:none;">
                <label class="ltu-auth-label" asp-for="ProductName">Product Name</label>
                <input class="ltu-auth-input" asp-for="ProductName" />
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <label class="ltu-auth-label" asp-for="HearAboutUs">How did you hear about us?</label>
                <select class="ltu-auth-select" asp-for="HearAboutUs">
                    <option value="">Select</option>
                    <option value="Email/Newsletter Blast">Email/Newsletter Blast</option>
                    <option value="Friend/Colleague">Friend/Colleague</option>
                    <option value="Internet Search">Internet Search</option>
                    <option value="Magazine or Newspaper Article">Magazine or Newspaper Article</option>
                    <option value="Print or Web Advertisement">Print or Web Advertisement</option>
                    <option value="Social Media (Facebook, Twitter, etc.)">Social Media (Facebook, Twitter, etc.)</option>
                </select>
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="Username">Username*</label>
                <input class="ltu-auth-input @(highlightUsername ? "membership-invalid" : null)" asp-for="Username" data-required="true" autocomplete="username" />
            </div>

            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="Password">Password*</label>
                <input class="ltu-auth-input @(highlightPassword ? "membership-invalid" : null)" asp-for="Password" id="Password" type="password" data-required="true" minlength="8" maxlength="100" autocomplete="new-password" />
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <label class="ltu-auth-label" asp-for="ConfirmPassword">Confirm Password*</label>
                <input class="ltu-auth-input @(highlightPassword ? "membership-invalid" : null)" asp-for="ConfirmPassword" id="ConfirmPassword" type="password" data-required="true" minlength="8" maxlength="100" autocomplete="new-password" />
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <div id="registerPasswordError" class="membership-alert membership-alert-error membership-alert-animated register-errors register-errors-password" style="display:none;"></div>
            </div>

            <div class="ltu-auth-field ltu-auth-field--full">
                <div class="ltu-auth-checks">
                    <div class="ltu-auth-check-row form-item-checkbox">
                        <label class="ltu-auth-check">
                            <input class="register-checkbox" type="checkbox" id="OptIn" name="OptIn" value="true" @(Model.OptIn ? "checked" : null) />
                            <span>I would like to receive information from Laser Therapy University.</span>
                        </label>
                    </div>

                    <div class="ltu-auth-check-row form-item-checkbox">
                        <label class="ltu-auth-check">
                            <input class="register-checkbox" type="checkbox" id="AcceptedTerms" name="AcceptedTerms" value="true" @(Model.AcceptedTerms ? "checked" : null) data-required="true" />
                            <span>*I agree to the <a href="/terms-and-conditions" target="_blank">Terms &amp; Conditions</a></span>
                        </label>
                        <span class="checkbox-error" id="AcceptedTermsError"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="ltu-auth-actions" style="margin-top:18px;">
            <button type="submit" class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide">Submit</button>
        </div>
    </form>

    <aside class="ltu-auth-card ltu-auth-card--accent">
        <p class="ltu-auth-eyebrow">What you get</p>
        <h2 class="ltu-auth-title">Built for paid access</h2>
        <p class="ltu-auth-copy">Your LTU member profile becomes the source of truth for purchases, recent views, and access to premium learning materials.</p>
        <ul class="ltu-auth-list">
            <li>Profile-based access to paid webinars, videos, protocols, and research</li>
            <li>Stripe checkout with your member details prefilled when available</li>
            <li>Purchase confirmations sent to both user and admin</li>
            <li>Recently viewed history inside My Profile</li>
        </ul>
        <div class="ltu-auth-aside-links">
            <a class="ltu-flow-btn ltu-flow-btn--ghost ltu-flow-btn--wide" href="/members/log-in/">Already have an account?</a>
        </div>
    </aside>
</section>

<script>
    (function () {
        var form = document.getElementById("membershipRegisterForm");
        var productOwned = document.getElementById("ProductOwned");
        var country = document.getElementById("Country");
        var productWrap = document.getElementById("productNameWrap");
        var stateWrap = document.getElementById("stateWrap");
        var errorSummary = document.getElementById("registerErrorSummary");
        var acceptedTermsError = document.getElementById("AcceptedTermsError");
        var passwordError = document.getElementById("registerPasswordError");
        var password = document.getElementById("Password");
        var confirmPassword = document.getElementById("ConfirmPassword");

        function toggleProductName() {
            if (!productWrap || !productOwned) {
                return;
            }
            productWrap.style.display = productOwned.value === "Other" ? "" : "none";
        }

        function toggleState() {
            if (!stateWrap || !country) {
                return;
            }
            stateWrap.style.display = country.value === "United States" ? "" : "none";
        }

        function validateField(field) {
            if (!field || field.dataset.required !== "true") {
                return true;
            }

            if (field.type === "checkbox") {
                return field.checked;
            }

            return (field.value || "").trim().length > 0;
        }

        function markField(field, invalid) {
            if (!field) {
                return;
            }
            if (field.type === "checkbox") {
                var row = field.closest(".ltu-auth-check-row");
                if (row) {
                    row.classList.toggle("membership-invalid-checkbox", invalid);
                }
                return;
            }
            field.classList.toggle("membership-invalid", invalid);
        }

        function setTextError(element, message) {
            if (!element) {
                return;
            }

            element.textContent = message || "";
            element.style.display = message ? "block" : "none";
        }

        function validatePasswords() {
            if (!password || !confirmPassword) {
                return [];
            }

            var errors = [];
            var passwordInvalid = password.value.length > 0 && (password.value.length < 8 || password.value.length > 100);
            var confirmInvalid = confirmPassword.value.length > 0 && password.value !== confirmPassword.value;

            if (passwordInvalid) {
                errors.push("Password must be 8-100 characters.");
            }

            if (confirmInvalid) {
                errors.push("Password and Confirm Password do not match.");
            }

            markField(password, passwordInvalid);
            markField(confirmPassword, confirmInvalid);
            setTextError(passwordError, errors.join(" "));

            return errors;
        }

        if (productOwned) {
            productOwned.addEventListener("change", toggleProductName);
            toggleProductName();
        }

        if (country) {
            country.addEventListener("change", toggleState);
            toggleState();
        }

        if (!form) {
            return;
        }

        var requiredFields = form.querySelectorAll("[data-required='true']");

        requiredFields.forEach(function (field) {
            field.addEventListener("input", function () {
                markField(field, !validateField(field));
                if (field === password || field === confirmPassword) {
                    validatePasswords();
                }
            });
            field.addEventListener("change", function () {
                markField(field, !validateField(field));
                if (field === password || field === confirmPassword) {
                    validatePasswords();
                }
            });
        });

        form.addEventListener("submit", function (e) {
            var hasErrors = false;
            var errors = [];

            requiredFields.forEach(function (field) {
                var invalid = !validateField(field);
                markField(field, invalid);
                if (invalid) {
                    hasErrors = true;
                    if (field.id === "AcceptedTerms") {
                        errors.push("You must accept Terms & Conditions.");
                    }
                }
            });

            var passwordErrors = validatePasswords();
            if (passwordErrors.length > 0) {
                hasErrors = true;
                errors = errors.concat(passwordErrors);
            }

            if (hasErrors) {
                if (errorSummary) {
                    errorSummary.style.display = "block";
                    errorSummary.textContent = errors.length > 0
                        ? errors.join(" ")
                        : "Please fill in all required fields.";
                }
                if (acceptedTermsError) {
                    acceptedTermsError.textContent = errors.some(function (x) { return x.indexOf("Terms") >= 0; })
                        ? "Required"
                        : "";
                }
                e.preventDefault();
                return;
            }

            if (errorSummary) {
                errorSummary.style.display = "none";
                errorSummary.textContent = "";
            }
            if (acceptedTermsError) {
                acceptedTermsError.textContent = "";
            }
            setTextError(passwordError, "");
        });
    })();
</script>
