@model LTU_U15.Models.Membership.ForgotPasswordViewModel

@{
    var message = TempData["MembershipMessage"] as string;
    var hasMessage = !string.IsNullOrWhiteSpace(message);
}

<section class="ltu-auth-shell ltu-auth-shell--split">
    <form method="post" action="/account/forgot-password" class="ltu-auth-card ltu-auth-form" id="forgotPasswordForm" novalidate>
        @Html.AntiForgeryToken()

        <p class="ltu-auth-eyebrow">Member Support</p>
        <h2 class="ltu-auth-title">Reset your password</h2>
        <p class="ltu-auth-copy">Enter the email associated with your account. A temporary password will be emailed to you.</p>

        @if (hasMessage)
        {
            <div class="membership-alert membership-alert-success membership-alert-animated" role="alert">@message</div>
        }

        <div class="membership-alert membership-alert-error membership-alert-animated membership-inline-error" id="forgotPasswordClientError" style="display:none;"></div>

        <div class="ltu-auth-grid" style="margin-top:18px;">
            <div class="ltu-auth-field">
                <label class="ltu-auth-label" asp-for="Email">Email Address*</label>
                <input class="ltu-auth-input" asp-for="Email" autocomplete="email" />
            </div>
        </div>

        <div class="ltu-auth-actions">
            <button type="submit" class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide">Reset Password</button>
        </div>
    </form>

    <aside class="ltu-auth-card ltu-auth-card--accent">
        <p class="ltu-auth-eyebrow">Need a different fix?</p>
        <h2 class="ltu-auth-title">Still cannot sign in?</h2>
        <p class="ltu-auth-copy">If you do not remember your username, use the username recovery page first and then return here.</p>
        <div class="ltu-auth-aside-links">
            <a class="ltu-flow-btn ltu-flow-btn--accent ltu-flow-btn--wide" href="/members/forgot-username/">Retrieve Username</a>
            <a class="ltu-flow-btn ltu-flow-btn--ghost ltu-flow-btn--wide" href="/members/log-in/">Back to Log In</a>
        </div>
    </aside>
</section>

<script>
    (function () {
        var form = document.getElementById("forgotPasswordForm");
        if (!form) {
            return;
        }

        var email = form.querySelector("[name='Email']");
        var errorBox = document.getElementById("forgotPasswordClientError");

        function showError(message) {
            if (!errorBox) {
                return;
            }

            errorBox.textContent = message || "";
            errorBox.style.display = message ? "block" : "none";
        }

        form.addEventListener("submit", function (event) {
            var value = (email && email.value || "").trim();
            var invalid = !value || value.indexOf("@@") < 1;

            if (email) {
                email.classList.toggle("membership-invalid", invalid);
            }

            if (invalid) {
                event.preventDefault();
                showError("Please enter a valid email address.");
                return;
            }

            showError("");
        });
    })();
</script>
