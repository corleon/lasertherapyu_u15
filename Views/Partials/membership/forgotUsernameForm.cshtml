@model LTU_U15.Models.Membership.ForgotUsernameViewModel

<p>Enter the email associated with your account. Your username will be emailed to you.</p>

<form method="post" action="/account/forgot-username" class="content-form">
    @Html.AntiForgeryToken()

    @if (TempData["MembershipMessage"] is string message && !string.IsNullOrWhiteSpace(message))
    {
        <p>@message</p>
    }

    <label class="form-label" asp-for="Email">Email Address*</label>
    <input class="form-text-input" asp-for="Email" />

    <button type="submit" class="btn btn-blue">Retrieve Username</button>
</form>
