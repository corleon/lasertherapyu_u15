@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions
@{
    Layout = "master.cshtml";

    var webinarSections = Model.Children()
        .Where(x => x.IsVisible())
        .Select(x => new
        {
            Page = x,
            Image = x.Value<IPublishedContent>("mainImage"),
            Summary = x.Value<string>("subtitle")
                ?? x.Value<string>("metaDescription")
                ?? x.Name
        })
        .ToList();
}

<div class="content-wrapper">
    <header class="content-header content-header-has-icon">
        <div class="content-header-icon">
            <img src="/images/icon_webinars.png" alt="Webinars" width="145" height="109" />
        </div>
        <div>
            <h1 class="content-header-h1">Webinars</h1>
            <div class="content-header-copy">
                <p>Live and on-demand education sessions focused on clinical outcomes, treatment strategy, and real-world laser therapy implementation.</p>
                <p>Use LTU webinars to stay current, sharpen protocol decisions, and jump back into paid or free sessions whenever you need fast answers.</p>
            </div>
        </div>
    </header>
</div>

<section class="content-wrapper ltu-hub-grid">
    @foreach (var webinarSection in webinarSections)
    {
        <article class="ltu-hub-card">
            <a class="ltu-hub-card__media" href="@webinarSection.Page.Url()">
                <img src="@(webinarSection.Image?.Url() ?? "/images/prerecorded_webinars.jpg")" alt="@webinarSection.Page.Name" />
            </a>
            <div class="ltu-hub-card__body">
                <p class="ltu-hub-card__eyebrow">Webinar Collection</p>
                <h2 class="ltu-hub-card__title">@webinarSection.Page.Name</h2>
                @if (!string.IsNullOrWhiteSpace(webinarSection.Summary))
                {
                    <p class="ltu-hub-card__copy">@webinarSection.Summary</p>
                }
                <a class="ltu-flow-btn ltu-flow-btn--primary" href="@webinarSection.Page.Url()">Explore</a>
            </div>
        </article>
    }
</section>
