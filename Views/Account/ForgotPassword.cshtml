@model LTU_U15.Models.Membership.ForgotPasswordViewModel
@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "Forgot Your Password?";
}

<p>Enter the email associated with your account. A temporary password will be emailed to you.</p>

<form method="post" action="/account/forgot-password" class="content-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly"></div>

    <label class="form-label" asp-for="Email">Email Address*</label>
    <input class="form-text-input" asp-for="Email" />

    <button type="submit" class="btn btn-blue">Reset Password</button>
</form>
