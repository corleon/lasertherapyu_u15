@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = "master.cshtml";

    var pageTitle = Model.Value<string>("title");
    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = Model.Name;
    }

    var contentHtml = Model.Value<string>("content");
    var contentRows = Model.Value<Umbraco.Cms.Core.Models.Blocks.BlockListModel>("contentRows");
}

<div class="content-wrapper content-has-breadcrumb">
    <nav class="breadcrumb-nav">
        <a title="Home" href="/">Home</a>
        <span>@Model.Name</span>
    </nav>

    <header class="content-header">
        <h1 class="content-header-h1">@pageTitle</h1>
    </header>

    <article class="content-article">
        @if (!string.IsNullOrWhiteSpace(contentHtml))
        {
            @Html.Raw(contentHtml)
        }
        else if (contentRows != null && contentRows.Any())
        {
            @Html.GetBlockListHtml(contentRows)
        }
    </article>
</div>
