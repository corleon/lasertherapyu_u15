@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using LTU_U15.Models.Membership
@using System.Text.Json
@using Umbraco.Extensions
@inject Umbraco.Cms.Core.Security.IMemberManager MemberManager

@{
    Layout = "master.cshtml";

    var pageTitle = Model.Value<string>("title");
    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = Model.Name;
    }

    var contentHtml = Model.Value<string>("content");
    var contentRows = Model.Value<Umbraco.Cms.Core.Models.Blocks.BlockListModel>("contentRows");
    var isMembershipPage = Model.AncestorsOrSelf().Any(x => x.Name.Equals("Members", StringComparison.OrdinalIgnoreCase));
    var pageSlug = (Model.UrlSegment ?? string.Empty).ToLowerInvariant();
    var returnUrlQuery = Context?.Request?.Query["r"].ToString();
    var currentMember = await MemberManager.GetCurrentMemberAsync();
    var isMemberLoggedIn = currentMember != null;
    var articleClass = isMembershipPage ? "content-article content-article--membership" : "content-article ltu-rich-content";

    var registerModel = new RegisterMemberViewModel { ReturnUrl = returnUrlQuery };
    if (TempData.TryGetValue("RegistrationModel", out var registrationModelRaw) && registrationModelRaw is string registrationModelJson)
    {
        try
        {
            registerModel = JsonSerializer.Deserialize<RegisterMemberViewModel>(registrationModelJson) ?? new RegisterMemberViewModel();
        }
        catch
        {
            registerModel = new RegisterMemberViewModel();
        }
    }
}

@{
    if (isMembershipPage && pageSlug == "members")
    {
        Context.Response.Redirect("/members/my-profile/");
        return;
    }
}

<div class="content-wrapper content-has-breadcrumb">
    <nav class="breadcrumb-nav">
        @foreach (var ancestor in Model.Ancestors().OrderBy(x => x.Level))
        {
            <a title="@ancestor.Name" href="@ancestor.Url()">@ancestor.Name</a>
        }
        <span>@Model.Name</span>
    </nav>

    <header class="content-header">
        <h1 class="content-header-h1">@pageTitle</h1>
    </header>

    <article class="@articleClass">
        @if (isMembershipPage && pageSlug == "log-in")
        {
            if (isMemberLoggedIn)
            {
                @await Html.PartialAsync("~/Views/Partials/membership/myProfile.cshtml")
            }
            else
            {
                @await Html.PartialAsync("~/Views/Partials/membership/loginForm.cshtml", new LoginMemberViewModel { ReturnUrl = returnUrlQuery })
            }
        }
        else if (isMembershipPage && pageSlug == "registration")
        {
            if (isMemberLoggedIn)
            {
                @await Html.PartialAsync("~/Views/Partials/membership/myProfile.cshtml")
            }
            else
            {
                @await Html.PartialAsync("~/Views/Partials/membership/registerForm.cshtml", registerModel)
            }
        }
        else if (isMembershipPage && pageSlug == "forgot-password")
        {
            @await Html.PartialAsync("~/Views/Partials/membership/forgotPasswordForm.cshtml", new ForgotPasswordViewModel())
        }
        else if (isMembershipPage && pageSlug == "forgot-username")
        {
            @await Html.PartialAsync("~/Views/Partials/membership/forgotUsernameForm.cshtml", new ForgotUsernameViewModel())
        }
        else if (isMembershipPage && pageSlug == "my-profile")
        {
            if (isMemberLoggedIn)
            {
                @await Html.PartialAsync("~/Views/Partials/membership/myProfile.cshtml")
            }
            else
            {
                @await Html.PartialAsync("~/Views/Partials/membership/loginForm.cshtml", new LoginMemberViewModel { ReturnUrl = Model.Url() })
            }
        }
        else if (!string.IsNullOrWhiteSpace(contentHtml))
        {
            @Html.Raw(contentHtml)
        }
        else if (contentRows != null && contentRows.Any())
        {
            @Html.GetBlockListHtml(contentRows)
        }
    </article>
</div>
