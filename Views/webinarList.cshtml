@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject IContentPurchaseService PurchaseService
@{
    Layout = "master.cshtml";
    var purchasedKeys = await PurchaseService.GetCurrentMemberPurchasedKeysAsync();
    var allWebinars = Model!.Children()
        .Where(x => x.IsPublished() && (x.ContentType.Alias == "veterinaryWebinar" || x.ContentType.Alias == "webinar"))
        .Where(x => x.Value<bool?>("active") != false)
        .OrderByDescending(x => x.Value<DateTime?>("date") ?? DateTime.MinValue)
        .ThenBy(x => x.Name)
        .ToList();

    string DisplayDate(IPublishedContent c) => c.Value<DateTime?>("date")?.ToString("MM/dd/yyyy") ?? string.Empty;
    string DisplayLength(IPublishedContent c) => (c.Value<string>("length") ?? string.Empty).Trim();
    string Summary(IPublishedContent c) => (c?.Value<string>("description") ?? string.Empty).Trim();
}

@await Html.PartialAsync("filterPanel", (Items: (IEnumerable<IPublishedContent>)allWebinars, Total: allWebinars.Count, ItemSelector: "webinar-item"))

<div class="content-wrapper content-webinars content-has-breadcrumb">
    <nav class="breadcrumb-nav">
        <a title="Home" href="/">Home</a>
        <span>@Model.Name</span>
    </nav>

    <header class="content-header content-header-has-icon">
        <div class="content-header-icon"><img src="/images/icon_webinars.png" alt="Webinars"></div>
        <div>
            <h1 class="content-header-h1">@Model.Name</h1>
            <div class="content-header-copy">Browse premium and open-access webinar training inside the updated LTU library. Use filters above to narrow by topic and tag.</div>
        </div>
    </header>

    <section class="listing">
        @if (!allWebinars.Any())
        {
            <div class="listing-item"><div class="ltu-empty-state">No webinars found.</div></div>
        }
        else
        {
            foreach (var w in allWebinars)
            {
                var title = w.Value<string>("title")?.Trim();
                var tagNodes = w.Value<IEnumerable<IPublishedContent>>("tags");
                var isPaid = PurchaseService.IsPaidContent(w);
                var isPurchased = isPaid && purchasedKeys.Contains(w.Key);
                var price = PurchaseService.GetPrice(w);
                var primaryActionClass = isPurchased ? "ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" : isPaid ? "ltu-flow-btn ltu-flow-btn--accent ltu-flow-btn--wide" : "ltu-flow-btn ltu-flow-btn--ghost ltu-flow-btn--wide";
                var tagKeys = tagNodes != null && tagNodes.Any() ? string.Join(",", tagNodes.Where(t => t != null).Select(t => t.Key.ToString())) : string.Empty;

                <div class="listing-item webinar-item" data-tags="@tagKeys" data-webinar-key="@w.Key">
                    <div class="ltu-resource-card__main">
                        <p class="ltu-resource-card__eyebrow">Webinar</p>
                        <h2 class="listing-item-h2">
                            @((string.IsNullOrWhiteSpace(title) ? w.Name : title))
                            @if (isPurchased)
                            {
                                <span class="purchase-badge ltu-listing-badge">Purchased</span>
                            }
                        </h2>
                        <div class="listing-item-description">@Html.Raw(Summary(w))</div>

                        @if (tagNodes != null && tagNodes.Any())
                        {
                            var tagsByCategory = tagNodes.Where(tag => tag != null && tag.Parent != null)
                                .GroupBy(tag => tag.Parent.Key)
                                .Select(g => new { Category = g.First().Parent, Tags = g.OrderBy(t => t.SortOrder).ToList() })
                                .OrderBy(g => g.Category?.Parent?.SortOrder ?? 0)
                                .ThenBy(g => g.Category?.SortOrder ?? 0)
                                .ToList();

                            <div class="tags">
                                <div class="tagHead">Tags</div>
                                <div class="theTags">
                                    @foreach (var categoryGroup in tagsByCategory)
                                    {
                                        <div class="theTags__group">
                                            <span class="typeTag">@(categoryGroup.Category?.Value<string>("categoryTitle") ?? categoryGroup.Category?.Name)</span>
                                            @foreach (var tag in categoryGroup.Tags)
                                            {
                                                <span class="theTags__chip" data-tag-key="@tag.Key">@(tag.Value<string>("tagName") ?? tag.Name)</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <aside class="ltu-resource-card__meta">
                        <div class="ltu-resource-detail__meta">
                            @if (!string.IsNullOrWhiteSpace(DisplayLength(w)))
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Length</span><span class="ltu-resource-detail__meta-value">@DisplayLength(w)</span></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(DisplayDate(w)))
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Date</span><span class="ltu-resource-detail__meta-value">@DisplayDate(w)</span></div>
                            }
                            @if (price.HasValue)
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Price</span><span class="ltu-resource-detail__meta-value">$@price.Value.ToString("0.00")</span></div>
                            }
                        </div>

                        <ul class="listing-item-btns ltu-listing-actions">
                            <li class="listing-item-btn">
                                <a class="@primaryActionClass" href="@(isPaid && !isPurchased ? $"/billing/checkout?contentKey={w.Key}&returnUrl={Uri.EscapeDataString(w.Url() ?? "/webinars/")}" : w.Url())">@(isPurchased ? "Open" : (isPaid ? "Buy Now" : "Learn More"))</a>
                            </li>
                            @if (isPaid && !isPurchased)
                            {
                                <li class="listing-item-btn">
                                    <form method="post" action="/cart/add">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="contentKey" value="@w.Key" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide">Add to Cart</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </aside>
                </div>
            }
        }
    </section>
</div>
