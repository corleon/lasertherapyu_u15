@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using System
@using System.Linq
@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inject IContentPurchaseService PurchaseService
@{
    Layout = "master.cshtml";

    var webinarsRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "webinars" && x.IsPublished());
    var preRecordedWebinars = webinarsRoot?
        .Children()
        .FirstOrDefault(x => x.ContentType.Alias == "webinarList" && x.IsPublished() && x.Name.Contains("Pre-Recorded", StringComparison.OrdinalIgnoreCase))
        ?? webinarsRoot?.Children().FirstOrDefault(x => x.ContentType.Alias == "webinarList" && x.IsPublished());

    var webinarItems = (preRecordedWebinars?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && (x.ContentType.Alias == "veterinaryWebinar" || x.ContentType.Alias == "webinar") && x.Value<bool?>("active") != false)
        .OrderByDescending(x => x.Value<DateTime?>("date") ?? DateTime.MinValue)
        .ThenBy(x => x.Name)
        .Take(3)
        .ToList();
    var webinarCount = (preRecordedWebinars?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Count(x => x.IsPublished() && (x.ContentType.Alias == "veterinaryWebinar" || x.ContentType.Alias == "webinar") && x.Value<bool?>("active") != false);

    var researchRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "researchList" && x.IsPublished());
    var researchItems = (researchRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && x.ContentType.Alias == "research")
        .OrderByDescending(x => x.Value<DateTime?>("articleDate") ?? DateTime.MinValue)
        .ThenBy(x => x.Value<string>("articleTitle") ?? x.Value<string>("headline") ?? x.Name)
        .Take(3)
        .ToList();
    var researchCount = (researchRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Count(x => x.IsPublished() && x.ContentType.Alias == "research");

    var protocolsRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "protocolsList" && x.IsPublished());
    var protocolItems = (protocolsRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && x.ContentType.Alias == "protocol")
        .OrderBy(x => x.SortOrder)
        .ThenBy(x => x.Value<string>("headline") ?? x.Name)
        .Take(3)
        .ToList();
    var protocolCount = (protocolsRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Count(x => x.IsPublished() && x.ContentType.Alias == "protocol");

    var videosRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "videoList" && x.IsPublished());
    var videoItems = (videosRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && x.ContentType.Alias == "video")
        .OrderByDescending(x => x.Value<DateTime?>("date") ?? DateTime.MinValue)
        .ThenBy(x => x.Name)
        .Take(3)
        .ToList();
    var videoCount = (videosRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Count(x => x.IsPublished() && x.ContentType.Alias == "video");

    var featuredItem = webinarItems.FirstOrDefault() ?? protocolItems.FirstOrDefault() ?? researchItems.FirstOrDefault() ?? videoItems.FirstOrDefault();

    string ResourceTitle(IPublishedContent item)
    {
        if (item.ContentType.Alias == "research")
        {
            return item.Value<string>("articleTitle")?.Trim() ?? item.Value<string>("headline")?.Trim() ?? item.Name;
        }

        return item.Value<string>("title")?.Trim() ?? item.Value<string>("headline")?.Trim() ?? item.Name;
    }

    string ResourceMeta(IPublishedContent item)
    {
        var date = item.Value<DateTime?>("date") ?? item.Value<DateTime?>("articleDate");
        return date.HasValue ? date.Value.ToString("MMM d, yyyy") : "Available now";
    }

    string PriceLabel(IPublishedContent item)
    {
        var price = PurchaseService.GetPrice(item);
        return price.HasValue ? "$" + price.Value.ToString("0.00") : "Open Access";
    }
}

<section class="ltu-home">
    <section class="ltu-home__hero">
        <div>
            <p class="ltu-home__kicker">Laser Therapy University</p>
            <h1 class="ltu-home__headline">Clinical laser therapy, re-framed.</h1>
            <p class="ltu-home__copy">Build a sharper education workflow across webinars, protocols, research, and video training. LTU now runs as one premium learning library with member access, checkout, history tracking, and fast re-entry to the resources that matter.</p>
            <div class="ltu-home__actions">
                <a class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" href="/members/registration/">Create Account</a>
                <a class="ltu-flow-btn ltu-flow-btn--accent ltu-flow-btn--wide" href="@(preRecordedWebinars?.Url() ?? "/webinars/")">Explore Library</a>
            </div>
        </div>

        <aside class="ltu-home__hero-card">
            <p class="ltu-home__kicker">Featured Resource</p>
            @if (featuredItem != null)
            {
                <h2 class="ltu-home__hero-card-title">@ResourceTitle(featuredItem)</h2>
                <p class="ltu-home__hero-card-copy">Move from discovery to purchase or immediate access without leaving the main LTU flow.</p>
                <div class="ltu-home__actions">
                    <a class="ltu-flow-btn ltu-flow-btn--ghost ltu-flow-btn--wide" href="@featuredItem.Url()">Open Resource</a>
                </div>
            }
            else
            {
                <h2 class="ltu-home__hero-card-title">Your library is ready</h2>
                <p class="ltu-home__hero-card-copy">Publish content into the core sections and it will surface here automatically.</p>
            }
        </aside>
    </section>

    <section class="ltu-home__stats">
        <article class="ltu-home__stat"><span class="ltu-home__stat-label">Webinars</span><strong class="ltu-home__stat-value">@webinarCount</strong></article>
        <article class="ltu-home__stat"><span class="ltu-home__stat-label">Protocols</span><strong class="ltu-home__stat-value">@protocolCount</strong></article>
        <article class="ltu-home__stat"><span class="ltu-home__stat-label">Research</span><strong class="ltu-home__stat-value">@researchCount</strong></article>
        <article class="ltu-home__stat"><span class="ltu-home__stat-label">Videos</span><strong class="ltu-home__stat-value">@videoCount</strong></article>
    </section>

    <section class="ltu-home__grid">
        <article class="ltu-home__section">
            <div class="ltu-home__section-top">
                <div class="ltu-home__section-icon"><img src="/images/icon_webinars.png" alt="Webinars" /></div>
                <div>
                    <h2 class="ltu-home__section-title">Webinars</h2>
                    <p class="ltu-home__section-copy">Current sessions, premium recordings, and fast access to expert-led training.</p>
                </div>
            </div>
            <div class="ltu-home__section-list">
                @foreach (var item in webinarItems)
                {
                    <article class="ltu-home__resource">
                        <h3 class="ltu-home__resource-title"><a href="@item.Url()">@ResourceTitle(item)</a></h3>
                        <div class="ltu-home__resource-meta"><span>@ResourceMeta(item)</span><span class="ltu-home__resource-pill">@PriceLabel(item)</span></div>
                    </article>
                }
            </div>
            <div class="ltu-home__section-footer"><a class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" href="@(preRecordedWebinars?.Url() ?? "/webinars/")">View All Webinars</a></div>
        </article>

        <article class="ltu-home__section">
            <div class="ltu-home__section-top">
                <div class="ltu-home__section-icon"><img src="/images/icon_protocols.png" alt="Protocols" /></div>
                <div>
                    <h2 class="ltu-home__section-title">Protocols</h2>
                    <p class="ltu-home__section-copy">Downloadable treatment protocols and premium pathway content for fast clinical use.</p>
                </div>
            </div>
            <div class="ltu-home__section-list">
                @foreach (var item in protocolItems)
                {
                    <article class="ltu-home__resource">
                        <h3 class="ltu-home__resource-title"><a href="@item.Url()">@ResourceTitle(item)</a></h3>
                        <div class="ltu-home__resource-meta"><span>@ResourceMeta(item)</span><span class="ltu-home__resource-pill">@PriceLabel(item)</span></div>
                    </article>
                }
            </div>
            <div class="ltu-home__section-footer"><a class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" href="@(protocolsRoot?.Url() ?? "/protocols/")">View All Protocols</a></div>
        </article>

        <article class="ltu-home__section">
            <div class="ltu-home__section-top">
                <div class="ltu-home__section-icon"><img src="/images/icon_research.png" alt="Research" /></div>
                <div>
                    <h2 class="ltu-home__section-title">Research</h2>
                    <p class="ltu-home__section-copy">Published studies and abstracts surfaced through a cleaner, filterable library.</p>
                </div>
            </div>
            <div class="ltu-home__section-list">
                @foreach (var item in researchItems)
                {
                    <article class="ltu-home__resource">
                        <h3 class="ltu-home__resource-title"><a href="@item.Url()">@ResourceTitle(item)</a></h3>
                        <div class="ltu-home__resource-meta"><span>@ResourceMeta(item)</span><span class="ltu-home__resource-pill">@PriceLabel(item)</span></div>
                    </article>
                }
            </div>
            <div class="ltu-home__section-footer"><a class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" href="@(researchRoot?.Url() ?? "/research/")">View All Research</a></div>
        </article>

        <article class="ltu-home__section">
            <div class="ltu-home__section-top">
                <div class="ltu-home__section-icon"><img src="/images/icon_videos.png" alt="Videos" /></div>
                <div>
                    <h2 class="ltu-home__section-title">Videos</h2>
                    <p class="ltu-home__section-copy">Video learning content grouped into the same premium access flow as the rest of the site.</p>
                </div>
            </div>
            <div class="ltu-home__section-list">
                @foreach (var item in videoItems)
                {
                    <article class="ltu-home__resource">
                        <h3 class="ltu-home__resource-title"><a href="@item.Url()">@ResourceTitle(item)</a></h3>
                        <div class="ltu-home__resource-meta"><span>@ResourceMeta(item)</span><span class="ltu-home__resource-pill">@PriceLabel(item)</span></div>
                    </article>
                }
            </div>
            <div class="ltu-home__section-footer"><a class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" href="@(videosRoot?.Url() ?? "/videos/")">View All Videos</a></div>
        </article>
    </section>
</section>
