<section class="dashboard">

    <div class="dashboard-column dashboard-column-1">

        <div id="content_0_controls_1_lvColumnOne_pnlModule_0" class="dashboard-item dashboard-webinars">

            <h2>Webinars</h2>
            <div id="content_0_controls_1_lvColumnOne_pnlIcon_0" class="dashboard-item-icon">

                <img id="content_0_controls_1_lvColumnOne_imgIcon_0" class="ress" data-original="/images/icon_webinars.png" width="145" height="109" data-large="145" data-narrow="128" data-small="145" src="/images/icon_webinars.png" />

            </div>

            <ul>
                @if (webinarItems.Any())
                {
                    for (var i = 0; i < webinarItems.Count; i++)
                    {
                        var item = webinarItems[i];
                        <li>
                            <span>@GetWebinarTitle(item)</span>
                            <a href="@item.Url()">
                                @if (i == 0)
                                {
                                    <span class="featured">Featured Webinar  </span>
                                }
                                <span class="priceHighlight">FREE</span>
                            </a>
                        </li>
                    }
                }
                else
                {
                    <li>
                        <span>No webinars found</span>
                    </li>
                }
            </ul>

            <a id="content_0_controls_1_lvColumnOne_hlViewAll_0" title="View All Webinars" href="@(preRecordedWebinars?.Url() ?? webinarsRoot?.Url() ?? "/webinars")">View All Webinars</a>

        </div>


        <div id="content_0_controls_1_lvColumnOne_pnlModule_1" class="dashboard-item dashboard-research">

            <h2>Research</h2>
            <div id="content_0_controls_1_lvColumnOne_pnlIcon_1" class="dashboard-item-icon">

                <img id="content_0_controls_1_lvColumnOne_imgIcon_1" class="ress" data-original="/images/icon_research.png" width="132" height="116" data-large="145" data-narrow="128" data-small="145" src="/images/icon_research.png" />

            </div>

            <ul>
                @if (researchItems.Any())
                {
                    for (var i = 0; i < researchItems.Count; i++)
                    {
                        var item = researchItems[i];
                        <li>
                            <span>@GetResearchTitle(item)</span>
                            <a href="@item.Url()">
                                @if (i == 0)
                                {
                                    <span class="featured">Featured Study  </span>
                                }
                                <span class="priceHighlight">FREE</span>
                            </a>
                        </li>
                    }
                }
                else
                {
                    <li>
                        <span>No studies found</span>
                    </li>
                }
            </ul>

            <a id="content_0_controls_1_lvColumnOne_hlViewAll_1" title="View All Studies" href="@(researchRoot?.Url() ?? "/research")">View All Studies</a>

        </div>


        <div id="content_0_controls_1_lvColumnOne_pnlModule_2" class="dashboard-item dashboard-protocols">

            <h2>Protocols</h2>
            <div id="content_0_controls_1_lvColumnOne_pnlIcon_2" class="dashboard-item-icon">

                <img id="content_0_controls_1_lvColumnOne_imgIcon_2" class="ress" data-original="/images/icon_protocols.png" width="100" height="118" data-large="145" data-narrow="128" data-small="145" src="/images/icon_protocols.png" />

            </div>

            <ul>
                @if (protocolItems.Any())
                {
                    for (var i = 0; i < protocolItems.Count; i++)
                    {
                        var item = protocolItems[i];
                        var priceLabel = GetProtocolPriceLabel(item);
                        var isFree = priceLabel.Equals("FREE", StringComparison.OrdinalIgnoreCase);
                        <li>
                            <span>@GetProtocolTitle(item)</span>
                            <a href="@item.Url()">
                                @if (i == 0)
                                {
                                    <span class="featured">Featured Protocol  </span>
                                }
                                @if (isFree)
                                {
                                    <span class="priceHighlight">@priceLabel</span>
                                }
                                else
                                {
                                    <span>@priceLabel</span>
                                }
                            </a>
                        </li>
                    }
                }
                else
                {
                    <li>
                        <span>No protocols found</span>
                    </li>
                }
            </ul>

            <a id="content_0_controls_1_lvColumnOne_hlViewAll_2" title="View All Protocols" href="@(protocolsRoot?.Url() ?? "/protocols")">View All Protocols</a>

        </div>





        <div id="content_0_controls_1_lvColumnOne_pnlModule_3" class="dashboard-item dashboard-videos">

            <h2>Videos</h2>
            <div id="content_0_controls_1_lvColumnOne_pnlIcon_3" class="dashboard-item-icon">

                <img id="content_0_controls_1_lvColumnOne_imgIcon_3" class="ress" data-original="/images/icon_videos.png" width="100" height="118" data-large="145" data-narrow="128" data-small="145" src="/images/icon_videos.png" />

            </div>

            <ul>
