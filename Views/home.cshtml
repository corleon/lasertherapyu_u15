@*  *@
<section class="ltu-home-grid">

    @*  *@
    <div class="ltu-sections-grid">

        @*  *@
        <div class="ltu-section-card ltu-section-card--webinars">
            <div class="ltu-section-card__head">
                <p class="ltu-section-card__eyebrow">Learning</p>
                <h2 class="ltu-section-card__title">Webinars</h2>
            </div>
            <div class="ltu-section-card__body">
                <ul class="ltu-section-card__list">
                    @if (webinarItems.Any())
                    {
                        for (var i = 0; i < webinarItems.Count; i++)
                        {
                            var item = webinarItems[i];
                            <li class="ltu-section-card__item">
                                <a href="@item.Url()" class="ltu-section-card__item-label">@GetWebinarTitle(item)</a>
                                <span class="ltu-section-card__item-meta">
                                    @if (i == 0)
                                    {
                                        <span class="ltu-section-card__featured">Featured</span>
                                    }
                                    <span class="ltu-section-card__price">FREE</span>
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ltu-section-card__item"><span class="ltu-section-card__item-label">No webinars found</span></li>
                    }
                </ul>
            </div>
            <div class="ltu-section-card__foot">
                <a class="ltu-flow-btn ltu-flow-btn--primary" href="@(preRecordedWebinars?.Url() ?? webinarsRoot?.Url() ?? "/webinars")">View All Webinars</a>
            </div>
        </div>

        @*  *@
        <div class="ltu-section-card ltu-section-card--research">
            <div class="ltu-section-card__head">
                <p class="ltu-section-card__eyebrow">Science</p>
                <h2 class="ltu-section-card__title">Research</h2>
            </div>
            <div class="ltu-section-card__body">
                <ul class="ltu-section-card__list">
                    @if (researchItems.Any())
                    {
                        for (var i = 0; i < researchItems.Count; i++)
                        {
                            var item = researchItems[i];
                            <li class="ltu-section-card__item">
                                <a href="@item.Url()" class="ltu-section-card__item-label">@GetResearchTitle(item)</a>
                                <span class="ltu-section-card__item-meta">
                                    @if (i == 0)
                                    {
                                        <span class="ltu-section-card__featured">Featured</span>
                                    }
                                    <span class="ltu-section-card__price">FREE</span>
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ltu-section-card__item"><span class="ltu-section-card__item-label">No studies found</span></li>
                    }
                </ul>
            </div>
            <div class="ltu-section-card__foot">
                <a class="ltu-flow-btn ltu-flow-btn--accent" href="@(researchRoot?.Url() ?? "/research")">View All Studies</a>
            </div>
        </div>

        @*  *@
        <div class="ltu-section-card ltu-section-card--protocols">
            <div class="ltu-section-card__head">
                <p class="ltu-section-card__eyebrow">Clinical</p>
                <h2 class="ltu-section-card__title">Protocols</h2>
            </div>
            <div class="ltu-section-card__body">
                <ul class="ltu-section-card__list">
                    @if (protocolItems.Any())
                    {
                        for (var i = 0; i < protocolItems.Count; i++)
                        {
                            var item = protocolItems[i];
                            var priceLabel = GetProtocolPriceLabel(item);
                            var isFree = priceLabel.Equals("FREE", StringComparison.OrdinalIgnoreCase);
                            <li class="ltu-section-card__item">
                                <a href="@item.Url()" class="ltu-section-card__item-label">@GetProtocolTitle(item)</a>
                                <span class="ltu-section-card__item-meta">
                                    @if (i == 0)
                                    {
                                        <span class="ltu-section-card__featured">Featured</span>
                                    }
                                    <span class="@(isFree ? "ltu-section-card__price" : "ltu-section-card__price ltu-section-card__price--paid")">@priceLabel</span>
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ltu-section-card__item"><span class="ltu-section-card__item-label">No protocols found</span></li>
                    }
                </ul>
            </div>
            <div class="ltu-section-card__foot">
                <a class="ltu-flow-btn ltu-flow-btn--ghost" href="@(protocolsRoot?.Url() ?? "/protocols")">View All Protocols</a>
            </div>
        </div>

        @*  *@
        <div class="ltu-section-card ltu-section-card--videos">
            <div class="ltu-section-card__head">
                <p class="ltu-section-card__eyebrow">Media</p>
                <h2 class="ltu-section-card__title">Videos</h2>
            </div>
            <div class="ltu-section-card__body">
                <ul class="ltu-section-card__list">
                    @if (videoItems.Any())
                    {
                        for (var i = 0; i < videoItems.Count; i++)
                        {
                            var item = videoItems[i];
                            <li class="ltu-section-card__item">
                                <a href="@item.Url()" class="ltu-section-card__item-label">@GetVideoTitle(item)</a>
                                <span class="ltu-section-card__item-meta">
                                    @if (i == 0)
                                    {
                                        <span class="ltu-section-card__featured">Featured</span>
                                    }
                                    <span class="ltu-section-card__price">FREE</span>
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ltu-section-card__item"><span class="ltu-section-card__item-label">No videos found</span></li>
                    }
                </ul>
            </div>
            <div class="ltu-section-card__foot">
                <a class="ltu-flow-btn ltu-flow-btn--ghost" href="@(videosRoot?.Url() ?? "/videos")" style="border-color:#c3b3de;color:#5c4490;">View All Videos</a>
            </div>
        </div>

    </div>

    @*  *@
    <aside class="ltu-home-sidebar">

        <div class="ltu-home-promo">
            <p class="ltu-home-promo__title">Upcoming Webinar</p>
            <a class="ltu-home-promo__img-wrap" href="https://register.gotowebinar.com/register/3636966107352339037?source=ltu">
                <img src="/images/0325_1.jpg" width="446" height="300" alt="Upcoming Webinar" />
            </a>
        </div>

        <div class="ltu-home-promo">
            <p class="ltu-home-promo__title">Subscribe Today</p>
            <a class="ltu-home-promo__img-wrap" href="https://www.lasertherapyu.org/subscriptions">
                <img src="/images/ltu_subscribe1.png" width="582" height="378" alt="Subscribe Today" />
            </a>
        </div>

        <div class="ltu-home-promo">
            <p class="ltu-home-promo__title">ProtocolBuild.com</p>
            <a class="ltu-home-promo__img-wrap" href="https://protocolbuild.com/">
                <img src="/images/pb.jpg" width="582" height="378" alt="ProtocolBuild" />
            </a>
        </div>

    </aside>

</section>
