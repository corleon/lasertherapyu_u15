                    </li>
                }
            </ul>


            <a id="content_0_controls_1_lvColumnOne_hlViewAll_3" title="View All Videos" href="@(videosRoot?.Url() ?? "/videos")">View All Videos</a>

        </div>
    </div>






    <div class="dashboard-column dashboard-column-2">


        <div id="content_0_controls_1_lvColumnTwo_pnlUpcomingItem_0" class="dashboard-upcoming-item dashboard-upcoming dashboard-upcoming-webinars">

