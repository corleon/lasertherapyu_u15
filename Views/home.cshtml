@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Home>

@using System
@using System.Linq
@using Umbraco.Cms.Core.Models.PublishedContent
@using Clean.Core.Models.ViewModels
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels

@{
    Layout = "master.cshtml";

    var webinarsRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "webinars" && x.IsPublished());
    var preRecordedWebinars = webinarsRoot?
        .Children()
        .FirstOrDefault(x => x.ContentType.Alias == "webinarList"
            && x.IsPublished()
            && x.Name.Contains("Pre-Recorded", StringComparison.OrdinalIgnoreCase))
        ?? webinarsRoot?
            .Children()
            .FirstOrDefault(x => x.ContentType.Alias == "webinarList" && x.IsPublished());

    var webinarItems = (preRecordedWebinars?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished()
            && (x.ContentType.Alias == "veterinaryWebinar" || x.ContentType.Alias == "webinar")
            && x.Value<bool?>("active") != false)
        .OrderByDescending(x => x.Value<DateTime?>("date") ?? DateTime.MinValue)
        .ThenBy(x => x.Name)
        .Take(3)
        .ToList();

    var researchRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "researchList" && x.IsPublished());
    var researchItems = (researchRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && x.ContentType.Alias == "research")
        .OrderByDescending(x => x.Value<DateTime?>("articleDate") ?? DateTime.MinValue)
        .ThenBy(x => x.Value<string>("articleTitle") ?? x.Value<string>("headline") ?? x.Name)
        .Take(3)
        .ToList();

    var protocolsRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "protocolsList" && x.IsPublished());
    var protocolItems = (protocolsRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && x.ContentType.Alias == "protocol")
        .OrderBy(x => x.SortOrder)
        .ThenBy(x => x.Value<string>("headline") ?? x.Name)
        .Take(3)
        .ToList();

    var videosRoot = Model.Children().FirstOrDefault(x => x.ContentType.Alias == "videoList" && x.IsPublished());
    var videoItems = (videosRoot?.Children() ?? Enumerable.Empty<IPublishedContent>())
        .Where(x => x.IsPublished() && x.ContentType.Alias == "video")
        .OrderByDescending(x => x.Value<DateTime?>("date") ?? DateTime.MinValue)
        .ThenBy(x => x.Name)
        .Take(3)
        .ToList();

    string GetWebinarTitle(IPublishedContent item) =>
        (item.Value<string>("title") ?? item.Name).Trim();

    string GetResearchTitle(IPublishedContent item)
    {
        var articleTitle = item.Value<string>("articleTitle")?.Trim();
        var headline = item.Value<string>("headline")?.Trim();
        return !string.IsNullOrWhiteSpace(articleTitle) ? articleTitle : (!string.IsNullOrWhiteSpace(headline) ? headline : item.Name);
    }

    string GetProtocolTitle(IPublishedContent item)
    {
        var headline = item.Value<string>("headline")?.Trim();
        return string.IsNullOrWhiteSpace(headline) ? item.Name : headline;
    }

    string GetVideoTitle(IPublishedContent item) =>
        (item.Value<string>("title") ?? item.Name).Trim();

    string GetProtocolPriceLabel(IPublishedContent item)
    {
        var salePrice = (item.Value<string>("salePrice") ?? "").Trim();
        if (!string.IsNullOrWhiteSpace(salePrice) && salePrice != "0" && salePrice != "0.00")
        {
            return salePrice.StartsWith("$", StringComparison.Ordinal) ? salePrice : $"${salePrice}";
        }

        var price = (item.Value<string>("price") ?? "").Trim();
        if (!string.IsNullOrWhiteSpace(price) && price != "0" && price != "0.00")
        {
            return price.StartsWith("$", StringComparison.Ordinal) ? price : $"${price}";
        }

        return "FREE";
    }
}

