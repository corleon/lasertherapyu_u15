@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<dynamic>
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Cms.Core.Security
@using Umbraco.Extensions
@using LTU_U15.Services.Commerce
@inject IMemberManager MemberManager
@inject ICartService CartService
@{
    Layout = null;

    string NormalizePath(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "/";
        }

        var normalized = value.Trim();
        if (!normalized.StartsWith('/'))
        {
            normalized = "/" + normalized;
        }

        return normalized.EndsWith('/') ? normalized[..^1] : normalized;
    }

    bool IsCurrent(params string[] prefixes)
    {
        foreach (var prefix in prefixes)
        {
            var normalizedPrefix = NormalizePath(prefix);
            if (normalizedPrefix == "/")
            {
                if (NormalizePath(Context?.Request?.Path.Value) == "/")
                {
                    return true;
                }

                continue;
            }

            var current = NormalizePath(Context?.Request?.Path.Value);
            if (current.Equals(normalizedPrefix, StringComparison.OrdinalIgnoreCase) || current.StartsWith(normalizedPrefix + "/", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }

    string NavClass(params string[] prefixes) => IsCurrent(prefixes) ? "is-active" : string.Empty;

    var currentYear = DateTime.UtcNow.Year;
    var currentMember = await MemberManager.GetCurrentMemberAsync();
    var isMemberLoggedIn = currentMember != null;
    var memberDisplayName = isMemberLoggedIn ? currentMember!.UserName : "Log In/Register";
    var profileUrl = "/members/my-profile/";
    var loginUrl = "/members/log-in/";
    var cartUrl = "/cart";
    var newsletterUrl = "/newsletter-signup/";
    var searchUrl = "/search/";
    var searchQuery = Context?.Request?.Query["q"].ToString() ?? string.Empty;
    var publishedPage = Model as IPublishedContent;
    var pageTitle = ViewData["Title"]?.ToString();
    if (string.IsNullOrWhiteSpace(pageTitle) && publishedPage != null)
    {
        pageTitle = publishedPage.Value<string>("title");
        if (string.IsNullOrWhiteSpace(pageTitle))
        {
            pageTitle = publishedPage.Value<string>("pageTitle");
        }
        if (string.IsNullOrWhiteSpace(pageTitle))
        {
            pageTitle = publishedPage.Name;
        }
    }
    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = "Laser Therapy University";
    }

    var cartSummary = await CartService.GetCartSummaryAsync();
    var cartCheckoutUrl = isMemberLoggedIn ? cartUrl : $"{loginUrl}?r=%2Fcart";
}
<!DOCTYPE html>
<html class="ltu-root" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle</title>
    <meta name="description" content="Evidence-based laser therapy education, protocols, webinars, research, and videos." />
    <meta property="og:site_name" content="Laser Therapy University" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.lasertherapyu.org/" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,600,700|Kameron:400,700" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="/css/global.css?v=635163774712393350" />
    <link rel="stylesheet" href="/css/ltu-commerce-ui.css?v=20260311-1" />
    <link rel="stylesheet" href="/css/ltu-site-theme.css?v=20260311-2" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/cookieconsent2/3.0.3/cookieconsent.min.css" />
    <script src="//cdnjs.cloudflare.com/ajax/libs/cookieconsent2/3.0.3/cookieconsent.min.js"></script>
    <script>
        window.addEventListener("load", function () {
            if (!window.cookieconsent) {
                return;
            }
            window.cookieconsent.initialise({
                palette: {
                    popup: { background: "#545654" },
                    button: { background: "#1f9847" }
                },
                theme: "classic",
                position: "top",
                static: true,
                type: "opt-out",
                content: { href: "https://www.lasertherapyu.org/privacy-policy/" }
            });
        });
    </script>
    <script>
        (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0], j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', 'GTM-TCB97RG');
    </script>
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="ltu-site-body @(IsCurrent("/") ? "is-home" : string.Empty)">
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TCB97RG" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <div class="ltu-site-overlay" data-shell-overlay></div>
    <div class="ltu-site-shell">
        <aside class="ltu-site-sidebar" id="ltuSiteSidebar">
            <div class="ltu-site-sidebar__brand">
                <a class="ltu-site-logo" href="/" aria-label="Laser Therapy University home">
                    <img src="/images/laser-therapy-university-logo.png" alt="Laser Therapy University" />
                </a>
                <p class="ltu-site-tagline">Evidence-based education, paid access, and clinical resources for modern laser therapy professionals.</p>
            </div>

            <div class="ltu-site-nav-groups">
                <section class="ltu-site-nav-card">
                    <p class="ltu-site-nav-title">Core Library</p>
                    <nav class="ltu-site-nav-list">
                        <a class="ltu-site-nav-link @NavClass("/webinars")" href="/webinars/">Webinars</a>
                        <a class="ltu-site-nav-link @NavClass("/protocols")" href="/protocols/">Protocols</a>
                        <a class="ltu-site-nav-link @NavClass("/research")" href="/research/">Research</a>
                        <a class="ltu-site-nav-link @NavClass("/videos")" href="/videos/">Videos</a>
                    </nav>
                </section>

                <a class="ltu-site-cta" href="/members/registration/">Join LTU</a>

                <section class="ltu-site-nav-card">
                    <p class="ltu-site-nav-title">Quick Links</p>
                    <nav class="ltu-site-nav-list">
                        <a class="ltu-site-nav-link @NavClass("/what-is-laser-therapy")" href="/what-is-laser-therapy/">What is Laser Therapy</a>
                        <a class="ltu-site-nav-link @NavClass("/members/my-profile", "/members/log-in", "/members/registration", "/members/forgot-password", "/members/forgot-username")" href="@profileUrl">My Profile</a>
                    </nav>
                </section>

                <section class="ltu-site-nav-card">
                    <p class="ltu-site-nav-title">More</p>
                    <nav class="ltu-site-nav-list">
                        <a class="ltu-site-nav-link @NavClass("/laser-news")" href="/laser-news/">Laser News</a>
                        <a class="ltu-site-nav-link @NavClass("/about-laser-therapy-university")" href="/about-laser-therapy-university/">About LTU</a>
                        <a class="ltu-site-nav-link @NavClass("/faqs")" href="/faqs/">FAQs</a>
                        <a class="ltu-site-nav-link @NavClass("/contact")" href="/contact/">Contact Us</a>
                    </nav>
                </section>
            </div>
            <section class="ltu-site-sidecard">
                <h2 class="ltu-site-sidecard__title">Stay in the loop</h2>
                <p class="ltu-site-sidecard__copy">Get announcements, premium releases, and new learning material updates from LTU.</p>
                <a class="ltu-site-cta" href="@newsletterUrl">Newsletter Sign Up</a>
                <div class="ltu-site-socials">
                    <a class="ltu-site-social" href="https://www.facebook.com/LaserTherapyU" target="_blank" rel="noreferrer">FB</a>
                    <a class="ltu-site-social" href="https://www.instagram.com/lasertherapyu/" target="_blank" rel="noreferrer">IG</a>
                </div>
            </section>
        </aside>

        <div class="ltu-site-main">
            <header class="ltu-site-topbar">
                <button type="button" class="ltu-site-topbar__toggle" data-sidebar-toggle>Menu</button>

                <form class="ltu-site-search" method="get" action="@searchUrl">
                    <div class="ltu-site-search__field">
                        <input type="search" name="q" value="@searchQuery" placeholder="Search LTU" aria-label="Search LTU" />
                        <button type="submit" class="ltu-site-search__submit">Go</button>
                    </div>
                    <a class="ltu-site-search__advanced" href="@searchUrl">Advanced Search</a>
                </form>

                <div class="ltu-site-topbar__actions">
                    <a class="ltu-site-utility" href="@newsletterUrl">Newsletter</a>
                    <a class="ltu-site-account @(isMemberLoggedIn ? "ltu-site-account--member" : string.Empty)" href="@(isMemberLoggedIn ? profileUrl : loginUrl)">@memberDisplayName</a>

                    <div class="ltu-site-cart" data-cart-root>
                        <button type="button" class="ltu-site-cart__button" data-cart-toggle aria-expanded="false" aria-controls="ltuCartPanel">
                            <span class="ltu-site-cart__icon">@cartSummary.Count</span>
                            <span class="ltu-site-cart__copy">
                                <span class="ltu-site-cart__count">@cartSummary.Count item@(cartSummary.Count == 1 ? string.Empty : "s")</span>
                                <span class="ltu-site-cart__label">View Cart</span>
                            </span>
                        </button>
                        <div class="ltu-site-cart__panel" id="ltuCartPanel" hidden>
                            <h2 class="ltu-site-cart__panel-title">Shopping Cart</h2>
                            @if (cartSummary.IsEmpty)
                            {
                                <p class="ltu-site-cart__empty">Your cart is currently empty.</p>
                            }
                            else
                            {
                                <div class="ltu-site-cart__list">
                                    @foreach (var item in cartSummary.Items)
                                    {
                                        <div class="ltu-site-cart__item">
                                            <a class="ltu-site-cart__item-title" href="@item.Url">@item.Name</a>
                                            <span class="ltu-site-cart__item-price">$@item.Price.ToString("0.00")</span>
                                        </div>
                                    }
                                </div>
                                <div class="ltu-site-cart__meta">
                                    <span>Subtotal</span>
                                    <strong>$@cartSummary.Subtotal.ToString("0.00")</strong>
                                </div>
                            }
                            <div class="ltu-site-cart__actions">
                                <a class="ltu-flow-btn ltu-flow-btn--primary" href="@cartUrl">View Cart</a>
                                @if (!cartSummary.IsEmpty)
                                {
                                    <a class="ltu-flow-btn ltu-flow-btn--accent" href="@cartCheckoutUrl">Check Out</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="ltu-site-page">
                @RenderBody()
            </main>

            <footer class="ltu-site-footer">
                <div class="ltu-site-footer__inner">
                    <div>
                        <p class="ltu-site-footer__brand">Laser Therapy University</p>
                        <p class="ltu-site-footer__copy">&copy; @currentYear LaserTherapyU.org, LLC. The scanning, uploading and distribution of LTU documents via the Internet or via any other means without permission of the author is illegal and punishable by law.</p>
                    </div>
                    <div class="ltu-site-footer__links">
                        <a href="/terms-and-conditions/">Terms &amp; Conditions</a>
                        <a href="/privacy-policy/">Privacy Policy</a>
                        <a href="/contact/">Contact</a>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            var body = document.body;
            var overlay = document.querySelector('[data-shell-overlay]');
            var sidebarToggle = document.querySelector('[data-sidebar-toggle]');
            var sidebar = document.getElementById('ltuSiteSidebar');
            var cartRoot = document.querySelector('[data-cart-root]');
            var cartToggle = document.querySelector('[data-cart-toggle]');
            var cartPanel = document.getElementById('ltuCartPanel');

            function closeSidebar() {
                body.classList.remove('ltu-sidebar-open');
            }

            function closeCart() {
                if (!cartPanel || !cartToggle) {
                    return;
                }
                cartPanel.setAttribute('hidden', 'hidden');
                cartToggle.setAttribute('aria-expanded', 'false');
                body.classList.remove('ltu-cart-open');
            }

            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function () {
                    body.classList.toggle('ltu-sidebar-open');
                });
            }

            if (cartToggle && cartPanel) {
                cartToggle.addEventListener('click', function () {
                    var isHidden = cartPanel.hasAttribute('hidden');
                    if (isHidden) {
                        cartPanel.removeAttribute('hidden');
                        cartToggle.setAttribute('aria-expanded', 'true');
                        body.classList.add('ltu-cart-open');
                    } else {
                        closeCart();
                    }
                });
            }

            if (overlay) {
                overlay.addEventListener('click', function () {
                    closeSidebar();
                    closeCart();
                });
            }

            document.addEventListener('click', function (event) {
                if (cartRoot && !cartRoot.contains(event.target)) {
                    closeCart();
                }
                if (window.innerWidth <= 1080 && sidebar && !sidebar.contains(event.target) && sidebarToggle && !sidebarToggle.contains(event.target)) {
                    closeSidebar();
                }
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeSidebar();
                    closeCart();
                }
            });
        })();
    </script>
</body>
</html>
