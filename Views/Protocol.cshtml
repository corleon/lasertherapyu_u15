@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject IContentPurchaseService PurchaseService

@{
    Layout = "master.cshtml";

    var isPaid = PurchaseService.IsPaidContent(Model);
    if (isPaid && !await PurchaseService.CurrentMemberHasPurchasedAsync(Model.Key))
    {
        var checkoutUrl = $"/billing/checkout?contentKey={Model.Key}&returnUrl={Uri.EscapeDataString(Model.Url() ?? "/")}";
        Context.Response.Redirect(checkoutUrl);
        return;
    }

    await PurchaseService.TrackCurrentMemberRecentlyViewedAsync(Model.Key);

    var pageTitle = Model?.Value<string>("pageTitle")?.Trim();
    var headline = Model?.Value<string>("headline")?.Trim() ?? "";
    var title = !string.IsNullOrWhiteSpace(headline) ? headline : (pageTitle ?? Model.Name);

    var shortDescriptionHtml = Model?.Value<string>("shortDescription") ?? "";
    var price = Model?.Value<string>("price") ?? "";
    var salePrice = Model?.Value<string>("salePrice") ?? "";
    var showDiagrams = Model?.Value<bool>("showDiagrams") ?? false;

    var protocolFile = Model?.Value<IPublishedContent>("protocolFile");
    var protocolFileUrl = protocolFile?.Url() ?? "";

    var diagramImage = Model?.Value<IPublishedContent>("diagramImages") ?? null;

    var crumbs = Model?.AncestorsOrSelf()?.OrderBy(x => x.Level).ToList() ?? new List<IPublishedContent>();

    var related = Model?.Siblings()?
        .Where(x => x.IsPublished() && x.ContentType.Alias == "protocol")
        .Take(3)
        .ToList() ?? new List<IPublishedContent>();

    string Summary(IPublishedContent c)
    {
        var html = c?.Value<string>("shortDescription") ?? "";
        return System.Net.WebUtility.HtmlDecode(html.StripHtml().Trim());
    }

    var displayPrice = "";
    var hasSale = !string.IsNullOrWhiteSpace(salePrice) && salePrice != "0" && salePrice != "0.00";
    if (hasSale)
    {
        displayPrice = salePrice;
    }
    else if (!string.IsNullOrWhiteSpace(price))
    {
        displayPrice = price;
    }
}

<div class="content-wrapper content-protocols content-has-breadcrumb">

    <nav class="breadcrumb-nav">
        @if (crumbs?.Any() == true)
        {
            foreach (var c in crumbs)
            {
                if (c.Id == Model.Id)
                {
                    <span>@c.Name</span>
                }
                else
                {
                    <a title="@c.Name" href="@c.Url()">@c.Name</a>
                }
            }
        }
    </nav>

    <header class="ltu-page-hero" style="background: radial-gradient(circle at top right, rgba(193,30,45,0.20), transparent 34%), linear-gradient(135deg, #3d1a1e 0%, #4a2226 55%, #006738 100%);">
        <p class="ltu-page-hero__eyebrow">Protocol</p>
        <h1 class="ltu-page-hero__title">@title</h1>
    </header>

    <article class="content-article">
        @if (!string.IsNullOrWhiteSpace(shortDescriptionHtml))
        {
            <div class="ltu-article-body">
                @Html.Raw(shortDescriptionHtml)
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(displayPrice))
        {
            <div class="ltu-protocol-price">
                <span class="ltu-protocol-price__label">Price</span>
                <span class="ltu-protocol-price__value">$@displayPrice</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(protocolFileUrl))
        {
            <div>
                <a class="ltu-flow-btn ltu-flow-btn--accent" href="@protocolFileUrl" target="_blank">Download Protocol</a>
            </div>
        }
    </article>

    @if (showDiagrams && diagramImage != null)
    {
        <section class="ltu-protocol-diagrams">
            <h2 class="ltu-protocol-diagrams__title">Diagrams</h2>
            <div class="ltu-protocol-diagrams__grid">
                @{
                    var imgUrl = diagramImage.Url();
                    var altText = diagramImage.Value<string>("altText") ?? diagramImage.Name;
                    <img src="@imgUrl?width=300&height=300" alt="@altText" />
                }
            </div>
        </section>
    }

    @if (related.Any())
    {
        <section class="ltu-related">
            <div class="ltu-related__header">
                <p class="ltu-related__kicker">Clinical Resources</p>
                <h2 class="ltu-related__title">Related Protocols</h2>
            </div>
            <div class="ltu-related__grid">
                @foreach (var p in related)
                {
                    var pTitle = p.Value<string>("headline");
                    if (string.IsNullOrWhiteSpace(pTitle)) pTitle = p.Name;
                    <div class="ltu-related__card" style="border-left-color: #c11e2d;">
                        <p class="ltu-related__card-section" style="color:#c11e2d;">Protocol</p>
                        <h3 class="ltu-related__card-title"><a href="@p.Url()">@pTitle</a></h3>
                        <p class="ltu-related__card-body">@Summary(p)</p>
                        <div>
                            <a class="ltu-flow-btn ltu-flow-btn--ghost" href="@p.Url()">View Protocol</a>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

</div>
