@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject IContentPurchaseService PurchaseService
@{
    Layout = "master.cshtml";

    var isPaid = PurchaseService.IsPaidContent(Model);
    if (isPaid && !await PurchaseService.CurrentMemberHasPurchasedAsync(Model.Key))
    {
        var checkoutUrl = $"/billing/checkout?contentKey={Model.Key}&returnUrl={Uri.EscapeDataString(Model.Url() ?? "/")}";
        Context.Response.Redirect(checkoutUrl);
        return;
    }

    await PurchaseService.TrackCurrentMemberRecentlyViewedAsync(Model.Key);

    var pageTitle = Model?.Value<string>("pageTitle")?.Trim();
    var headline = Model?.Value<string>("headline")?.Trim() ?? string.Empty;
    var title = !string.IsNullOrWhiteSpace(headline) ? headline : (pageTitle ?? Model.Name);
    var shortDescriptionHtml = Model?.Value<string>("shortDescription") ?? string.Empty;
    var price = Model?.Value<string>("price") ?? string.Empty;
    var salePrice = Model?.Value<string>("salePrice") ?? string.Empty;
    var showDiagrams = Model?.Value<bool>("showDiagrams") ?? false;
    var protocolFile = Model?.Value<IPublishedContent>("protocolFile");
    var protocolFileUrl = protocolFile?.Url() ?? string.Empty;
    var diagramImage = Model?.Value<IPublishedContent>("diagramImages");
    var related = Model?.Siblings()?.Where(x => x.IsPublished() && x.ContentType.Alias == "protocol").Take(3).ToList() ?? new List<IPublishedContent>();

    string Summary(IPublishedContent c) => System.Net.WebUtility.HtmlDecode((c?.Value<string>("shortDescription") ?? string.Empty).StripHtml().Trim());
    var displayPrice = !string.IsNullOrWhiteSpace(salePrice) && salePrice != "0" && salePrice != "0.00" ? salePrice : price;
}

<div class="content-wrapper content-protocols content-has-breadcrumb">
    <nav class="breadcrumb-nav">
        @foreach (var c in Model.Ancestors().OrderBy(x => x.Level))
        {
            <a title="@c.Name" href="@c.Url()">@c.Name</a>
        }
        <span>@title</span>
    </nav>

    <header class="content-header content-header-has-icon">
        <div class="content-header-icon"><img src="/images/icon_protocols.png" alt="Protocols"></div>
        <div>
            <h1 class="content-header-h1">@title</h1>
            <div class="content-header-copy">Premium protocol content with member-linked access, download support, and direct return paths from your LTU profile.</div>
        </div>
    </header>

    <section class="ltu-resource-detail">
        <div class="ltu-resource-detail__grid">
            <article class="ltu-resource-detail__main">
                <div class="ltu-resource-detail__body ltu-rich-content">@Html.Raw(shortDescriptionHtml)</div>

                @if (showDiagrams && diagramImage != null)
                {
                    var imgUrl = diagramImage.Url();
                    var altText = diagramImage.Value<string>("altText") ?? diagramImage.Name;
                    <div class="ltu-resource-detail__body">
                        <h2>Protocol Diagram</h2>
                        <img src="@imgUrl" alt="@altText" />
                    </div>
                }
            </article>

            <aside class="ltu-resource-detail__sidebar-card">
                <p class="ltu-resource-detail__sidebar-kicker">Protocol Access</p>
                <h2 class="ltu-resource-detail__sidebar-title">Download and return from My Profile</h2>
                <p class="ltu-resource-detail__sidebar-copy">Purchased protocols stay attached to your member account for direct re-entry later.</p>
                <div class="ltu-resource-detail__meta">
                    @if (!string.IsNullOrWhiteSpace(displayPrice))
                    {
                        <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Price</span><span class="ltu-resource-detail__meta-value">$@displayPrice</span></div>
                    }
                </div>
                <div class="ltu-resource-detail__downloads">
                    @if (!string.IsNullOrWhiteSpace(protocolFileUrl))
                    {
                        <a class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" href="@protocolFileUrl" target="_blank">Download Protocol</a>
                    }
                    <a class="ltu-flow-btn ltu-flow-btn--ghost ltu-flow-btn--wide" href="/protocols/">Back to Protocols</a>
                </div>
            </aside>
        </div>

        @if (related.Any())
        {
            <section class="related-products">
                <h2 class="related-products-h2">Related Protocols</h2>
                <div class="related-products-wrapper">
                    @foreach (var p in related)
                    {
                        var pTitle = p.Value<string>("headline");
                        if (string.IsNullOrWhiteSpace(pTitle)) { pTitle = p.Name; }
                        <article class="related-products-item">
                            <h3 class="related-products-h3">@pTitle</h3>
                            <div class="related-products-description">@Summary(p)</div>
                            <a class="related-products-link" href="@p.Url()">View Protocol</a>
                        </article>
                    }
                </div>
            </section>
        }
    </section>
</div>
