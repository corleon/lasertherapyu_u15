@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core
@using Umbraco.Cms.Core.Models.PublishedContent
@inject Umbraco.Cms.Core.IPublishedContentQuery publishedContentQuery
@{
    Layout = "master.cshtml";

    var searchQuery = Context.Request.Query["q"].ToString();
    var docTypesToIgnore = new[] { "category", "categoryList", "error", "search", "xMLSitemap" };
    var title = Model.Value<string>("title");
    if (string.IsNullOrWhiteSpace(title))
    {
        title = Model.Name;
    }

    var subtitle = Model.Value<string>("subtitle");
    var results = !string.IsNullOrWhiteSpace(searchQuery)
        ? publishedContentQuery.Search(searchQuery).Where(x => !docTypesToIgnore.Contains(x.Content.ContentType.Alias)).ToList()
        : null;
    var resultCount = results?.Count ?? 0;
}

<div class="content-wrapper content-has-breadcrumb">
    <nav class="breadcrumb-nav">
        <a title="Home" href="/">Home</a>
        <span>@title</span>
    </nav>

    <header class="content-header">
        <h1 class="content-header-h1">@title</h1>
        <div class="content-header-copy">@(string.IsNullOrWhiteSpace(subtitle) ? "Search across webinars, protocols, research, videos, and the rest of the LTU content library." : subtitle)</div>
    </header>

    <section class="ltu-page-grid">
        <article class="ltu-page-card">
            <p class="ltu-page-card__eyebrow">Library Search</p>
            <h2 class="ltu-page-card__title">Find the right resource</h2>
            <form action="@Model.Url()" method="get" class="ltu-search-form">
                <input type="search" class="ltu-search-input" placeholder="@Umbraco.GetDictionaryValue("Search.Placeholder")" name="q" value="@searchQuery" />
                <button class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" type="submit">@Umbraco.GetDictionaryValue("Search.SearchButton")</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                <div class="ltu-search-results">
                    <div class="ltu-empty-state">Found <strong>@resultCount</strong> result@(resultCount == 1 ? string.Empty : "s") for <strong>@searchQuery</strong>.</div>
                    @if (results != null)
                    {
                        foreach (var result in results)
                        {
                            var resultContent = result.Content;
                            var author = resultContent.HasProperty("author") && resultContent.HasValue("author") ? resultContent.Value<IPublishedContent>("author") : null;
                            var articleDate = resultContent.HasProperty("articleDate") && resultContent.HasValue("articleDate") ? resultContent.Value<DateTime?>("articleDate") : null;
                            var resultTitle = resultContent.HasProperty("title") && resultContent.HasValue("title") && !string.IsNullOrWhiteSpace(resultContent.Value<string>("title")) ? resultContent.Value<string>("title") : resultContent.Name;
                            var subtitleValue = resultContent.HasProperty("subtitle") && resultContent.HasValue("subtitle") ? resultContent.Value<string>("subtitle") : string.Empty;

                            <article class="ltu-search-result">
                                <h3 class="ltu-search-result__title"><a href="@resultContent.Url()">@resultTitle</a></h3>
                                @if (!string.IsNullOrWhiteSpace(subtitleValue))
                                {
                                    <div class="ltu-search-result__meta">@subtitleValue</div>
                                }
                                @if (author != null || (articleDate != null && articleDate > DateTime.MinValue))
                                {
                                    <div class="ltu-search-result__meta">
                                        @if (author != null)
                                        {
                                            <span>By @author.Name</span>
                                        }
                                        @if (articleDate != null && articleDate > DateTime.MinValue)
                                        {
                                            <span>@(author != null ? " | " : string.Empty)@articleDate.Value.ToString("MMMM dd, yyyy")</span>
                                        }
                                    </div>
                                }
                            </article>
                        }
                    }
                </div>
            }
        </article>

        <aside class="ltu-page-card ltu-page-card--accent">
            <p class="ltu-page-card__eyebrow">Tips</p>
            <h2 class="ltu-page-card__title">Search smarter</h2>
            <p class="ltu-page-card__copy">Use specific condition names, protocol topics, study keywords, or webinar subjects. The results view now stays inside the main LTU shell, so discovery feels like part of the product instead of a side page.</p>
            <ul class="ltu-page-card__list">
                <li>Try anatomy, diagnosis, treatment area, or therapy type</li>
                <li>Use filters inside section listing pages for narrower results</li>
                <li>Jump back into paid content from My Profile after purchase</li>
            </ul>
        </aside>
    </section>
</div>
