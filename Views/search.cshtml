@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@using Clean.Core.Models.ViewModels
@using Umbraco.Cms.Core
@using Umbraco.Cms.Core.Models.PublishedContent
@inject Umbraco.Cms.Core.IPublishedContentQuery publishedContentQuery

@{
    Layout = "master.cshtml";
    var searchQuery = Context.Request.Query["q"];
    var docTypesToIgnore = new[] { "category", "categoryList", "error", "search", "xMLSitemap" };

    var title = Model.Value<string>("title");
    var subtitle = Model.Value<string>("subtitle");
    var mainImage = Model.Value<IPublishedContent>("mainImage");
}

@await Html.PartialAsync("~/Views/Partials/pageHeader.cshtml", new PageHeaderViewModel(Model.Name, title, subtitle, mainImage))

<div class="content-wrapper">
    <div class="ltu-search-wrap">
        <form action="@Model.Url()" method="GET" id="search">
            <div class="ltu-search-form">
                <input type="text"
                       class="ltu-search-input"
                       placeholder="Search webinars, protocols, research, videos…"
                       name="q"
                       value="@searchQuery" />
                <button type="submit" class="ltu-flow-btn ltu-flow-btn--primary">Search</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var results = publishedContentQuery.Search(searchQuery).Where(x => !docTypesToIgnore.Contains(x.Content.ContentType.Alias));
                long resultCount = results != null && results.Any() ? results.Count() : 0;

                <p class="ltu-search-count">
                    @Html.Raw(string.Format(Umbraco.GetDictionaryValue("Search.Results"), resultCount, searchQuery))
                </p>

                @if (resultCount > 0)
                {
                    <div class="ltu-search-results">
                        @foreach (var result in results)
                        {
                            var resultContent = result.Content;
                            var author = resultContent.HasProperty("author") && resultContent.HasValue("author")
                                ? resultContent.Value<IPublishedContent>("author")
                                : null;
                            var articleDate = resultContent.HasProperty("articleDate") && resultContent.HasValue("articleDate")
                                ? resultContent.Value<DateTime?>("articleDate")
                                : null;

                            <div class="ltu-search-result">
                                <h2 class="ltu-search-result__title">
                                    <a href="@resultContent.Url()">
                                        @(resultContent.HasProperty("title") && resultContent.HasValue("title") && !string.IsNullOrWhiteSpace(resultContent.Value<string>("title")) ? resultContent.Value("title") : resultContent.Name)
                                    </a>
                                </h2>
                                @if (resultContent.HasProperty("subtitle") && resultContent.HasValue("subtitle") && !string.IsNullOrWhiteSpace(resultContent.Value<string>("subtitle")))
                                {
                                    <p class="ltu-search-result__subtitle">@(resultContent.Value<string>("subtitle"))</p>
                                }
                                @if (author != null || (articleDate != null && articleDate > DateTime.MinValue))
                                {
                                    <p class="ltu-search-result__meta">
                                        @Umbraco.GetDictionaryValue("Article.Posted")
                                        @if (author != null)
                                        {
                                            @Umbraco.GetDictionaryValue("Article.By")@Html.Raw("&nbsp;")@author.Name
                                        }
                                        @if (articleDate != null && articleDate > DateTime.MinValue)
                                        {
                                            @Umbraco.GetDictionaryValue("Article.On")
                                            @:&nbsp;@(articleDate.Value.ToString("MMMM dd, yyyy"))
                                        }
                                    </p>
                                }
                            </div>
                        }
                    </div>
                    <hr class="ltu-search-divider" />
                }
            }
        </form>
    </div>
</div>
