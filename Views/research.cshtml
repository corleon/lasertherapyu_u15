@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject IContentPurchaseService PurchaseService

@{
    Layout = "master.cshtml";

    var isPaid = PurchaseService.IsPaidContent(Model);
    if (isPaid && !await PurchaseService.CurrentMemberHasPurchasedAsync(Model.Key))
    {
        var checkoutUrl = $"/billing/checkout?contentKey={Model.Key}&returnUrl={Uri.EscapeDataString(Model.Url() ?? "/")}";
        Context.Response.Redirect(checkoutUrl);
        return;
    }

    await PurchaseService.TrackCurrentMemberRecentlyViewedAsync(Model.Key);

    var headline = Model?.Value<string>("headline")?.Trim();
    var articleTitle = Model?.Value<string>("articleTitle")?.Trim();
    var title = !string.IsNullOrWhiteSpace(articleTitle) ? articleTitle : (!string.IsNullOrWhiteSpace(headline) ? headline : Model.Name);

    var articleDate = Model?.Value<DateTime?>("articleDate");
    var articleContributors = Model?.Value<string>("articleContributors") ?? "";
    var journal = Model?.Value<string>("journal") ?? "";
    var articleReference = Model?.Value<string>("articleReference") ?? "";
    var shortDescription = Model?.Value<string>("shortDescription") ?? "";
    var articleCopy = Model?.Value<string>("articleCopy") ?? "";
    var linkToFullArticle = Model?.Value<string>("linkToFullArticle") ?? "";

    var articleUrl = linkToFullArticle;
    if (linkToFullArticle.Contains("url=\""))
    {
        var match = System.Text.RegularExpressions.Regex.Match(linkToFullArticle, @"url=""([^""]+)""");
        if (match.Success)
        {
            articleUrl = match.Groups[1].Value;
        }
    }

    var crumbs = Model?.AncestorsOrSelf()?.OrderBy(x => x.Level).ToList() ?? new List<IPublishedContent>();
}

<div class="content-wrapper content-research content-has-breadcrumb">

    <nav class="breadcrumb-nav">
        @if (crumbs?.Any() == true)
        {
            foreach (var c in crumbs)
            {
                if (c.Id == Model.Id)
                {
                    <span>@c.Name</span>
                }
                else
                {
                    <a title="@c.Name" href="@c.Url()">@c.Name</a>
                }
            }
        }
    </nav>

    <header class="ltu-page-hero" style="background: radial-gradient(circle at top right, rgba(0,103,56,0.28), transparent 34%), linear-gradient(135deg, #1a2d23 0%, #1f3728 55%, #0c5c97 100%);">
        <p class="ltu-page-hero__eyebrow">Research</p>
        <h1 class="ltu-page-hero__title">Laser Therapy Research</h1>
        @if (!string.IsNullOrWhiteSpace(shortDescription))
        {
            <p class="ltu-page-hero__description">@Html.Raw(shortDescription)</p>
        }
        else
        {
            <p class="ltu-page-hero__description">Laser Therapy U's online research portal houses an extensive collection of published studies, articles and abstracts from around the world.</p>
        }
    </header>

    <div class="ltu-study-card">
        <h2 class="ltu-study-title">@title</h2>

        @if (!string.IsNullOrWhiteSpace(journal))
        {
            <p class="ltu-study-journal">@journal</p>
        }

        @if (!string.IsNullOrWhiteSpace(articleContributors))
        {
            <p class="ltu-study-contributors">@Html.Raw(articleContributors)</p>
        }

        @if (articleDate.HasValue || !string.IsNullOrWhiteSpace(articleReference))
        {
            <div class="ltu-study-meta">
                @if (articleDate.HasValue)
                {
                    @articleDate.Value.ToString("M/d/yyyy")
                }
                @if (!string.IsNullOrWhiteSpace(articleReference))
                {
                    if (articleDate.HasValue)
                    {
                        <text> &mdash; </text>
                    }
                    @Html.Raw(articleReference)
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(articleCopy))
    {
        <article class="ltu-article-body">
            @Html.Raw(articleCopy)
        </article>
    }

    @if (!string.IsNullOrWhiteSpace(articleUrl))
    {
        <div style="margin-top: 8px;">
            <a class="ltu-flow-btn ltu-flow-btn--accent" href="@articleUrl" target="_blank">Link to Full Article</a>
        </div>
    }

</div>
