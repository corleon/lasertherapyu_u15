@using System.Text.RegularExpressions
@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject IContentPurchaseService PurchaseService
@{
    Layout = "master.cshtml";
    var purchasedKeys = await PurchaseService.GetCurrentMemberPurchasedKeysAsync();
    var allResearch = Model!.Children().Where(x => x.IsPublished() && x.ContentType.Alias == "research").OrderByDescending(x => x.Value<DateTime?>("articleDate") ?? DateTime.MinValue).ThenBy(x => x.Value<string>("headline") ?? x.Name).ToList();

    string DisplayDate(IPublishedContent c) => c.Value<DateTime?>("articleDate")?.ToString("M/d/yyyy") ?? string.Empty;
    string Summary(IPublishedContent c)
    {
        var html = c?.Value<string>("articleCopy") ?? string.Empty;
        var text = Regex.Replace(html, "<.*?>", " ");
        text = Regex.Replace(text, @"\s+", " ").Trim();
        return text.Length > 320 ? text[..320] + "..." : text;
    }
}

@await Html.PartialAsync("filterPanel", (Items: (IEnumerable<IPublishedContent>)allResearch, Total: allResearch.Count, ItemSelector: "research-item"))

<div class="content-wrapper content-research content-has-breadcrumb">
    <nav class="breadcrumb-nav">
        <a title="Home" href="/">Home</a>
        <span>@Model.Name</span>
    </nav>

    <header class="content-header content-header-has-icon">
        <div class="content-header-icon"><img src="/images/icon_research.png" alt="Research"></div>
        <div>
            <h1 class="content-header-h1">Laser Therapy Research</h1>
            <div class="content-header-copy">Search published studies, abstracts, and evidence summaries inside a cleaner research interface with filtering and premium access routing where needed.</div>
        </div>
    </header>

    <section class="listing">
        @if (!allResearch.Any())
        {
            <div class="listing-item"><div class="ltu-empty-state">No research found.</div></div>
        }
        else
        {
            foreach (var r in allResearch)
            {
                var headline = r.Value<string>("headline")?.Trim();
                var articleTitle = r.Value<string>("articleTitle")?.Trim();
                var title = !string.IsNullOrWhiteSpace(articleTitle) ? articleTitle : (!string.IsNullOrWhiteSpace(headline) ? headline : r.Name);
                var articleReference = r.Value<string>("articleReference") ?? string.Empty;
                var journal = r.Value<string>("journal") ?? string.Empty;
                var isPaid = PurchaseService.IsPaidContent(r);
                var isPurchased = isPaid && purchasedKeys.Contains(r.Key);
                var price = PurchaseService.GetPrice(r);
                var primaryActionClass = isPurchased ? "ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide" : isPaid ? "ltu-flow-btn ltu-flow-btn--accent ltu-flow-btn--wide" : "ltu-flow-btn ltu-flow-btn--ghost ltu-flow-btn--wide";
                var tagNodes = r.Value<IEnumerable<IPublishedContent>>("tags");
                var tagKeys = tagNodes != null && tagNodes.Any() ? string.Join(",", tagNodes.Where(t => t != null).Select(t => t.Key.ToString())) : string.Empty;

                <div class="listing-item research-item" data-tags="@tagKeys" data-research-key="@r.Key">
                    <div class="ltu-resource-card__main">
                        <p class="ltu-resource-card__eyebrow">Research</p>
                        <h2 class="listing-item-h2">
                            @title
                            @if (isPurchased)
                            {
                                <span class="purchase-badge ltu-listing-badge">Purchased</span>
                            }
                        </h2>
                        <div class="listing-item-description">@Summary(r)</div>

                        @if (tagNodes != null && tagNodes.Any())
                        {
                            var tagsByCategory = tagNodes.Where(tag => tag != null && tag.Parent != null)
                                .GroupBy(tag => tag.Parent.Key)
                                .Select(g => new { Category = g.First().Parent, Tags = g.OrderBy(t => t.SortOrder).ToList() })
                                .OrderBy(g => g.Category?.Parent?.SortOrder ?? 0)
                                .ThenBy(g => g.Category?.SortOrder ?? 0)
                                .ToList();

                            <div class="tags">
                                <div class="tagHead">Tags</div>
                                <div class="theTags">
                                    @foreach (var categoryGroup in tagsByCategory)
                                    {
                                        <div class="theTags__group">
                                            <span class="typeTag">@(categoryGroup.Category?.Value<string>("categoryTitle") ?? categoryGroup.Category?.Name)</span>
                                            @foreach (var tag in categoryGroup.Tags)
                                            {
                                                <span class="theTags__chip" data-tag-key="@tag.Key">@(tag.Value<string>("tagName") ?? tag.Name)</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <aside class="ltu-resource-card__meta">
                        <div class="ltu-resource-detail__meta">
                            @if (!string.IsNullOrWhiteSpace(DisplayDate(r)))
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Published</span><span class="ltu-resource-detail__meta-value">@DisplayDate(r)</span></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(journal))
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Journal</span><span class="ltu-resource-detail__meta-value">@journal</span></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(articleReference))
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Reference</span><span class="ltu-resource-detail__meta-value">@Html.Raw(articleReference)</span></div>
                            }
                            @if (price.HasValue)
                            {
                                <div class="ltu-resource-detail__meta-row"><span class="ltu-resource-detail__meta-label">Price</span><span class="ltu-resource-detail__meta-value">$@price.Value.ToString("0.00")</span></div>
                            }
                        </div>

                        <ul class="listing-item-btns ltu-listing-actions">
                            <li class="listing-item-btn">
                                <a class="@primaryActionClass" href="@(isPaid && !isPurchased ? $"/billing/checkout?contentKey={r.Key}&returnUrl={Uri.EscapeDataString(r.Url() ?? "/research/")}" : r.Url())">@(isPurchased ? "Open" : (isPaid ? "Buy Now" : "View Abstract"))</a>
                            </li>
                            @if (isPaid && !isPurchased)
                            {
                                <li class="listing-item-btn">
                                    <form method="post" action="/cart/add">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="contentKey" value="@r.Key" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="ltu-flow-btn ltu-flow-btn--primary ltu-flow-btn--wide">Add to Cart</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </aside>
                </div>
            }
        }
    </section>
</div>
