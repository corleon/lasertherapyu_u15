@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent
@using LTU_U15.Services.Commerce
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject IContentPurchaseService PurchaseService

@{
    Layout = "master.cshtml";

    var isPaid = PurchaseService.IsPaidContent(Model);
    if (isPaid && !await PurchaseService.CurrentMemberHasPurchasedAsync(Model.Key))
    {
        var checkoutUrl = $"/billing/checkout?contentKey={Model.Key}&returnUrl={Uri.EscapeDataString(Model.Url() ?? "/")}";
        Context.Response.Redirect(checkoutUrl);
        return;
    }

    await PurchaseService.TrackCurrentMemberRecentlyViewedAsync(Model.Key);

    var pageTitle = Model?.Value<string>("pageTitle")?.Trim();
    var title = (Model?.Value<string>("title")?.Trim() ?? pageTitle ?? "");

    var descriptionHtml = Model?.Value<string>("description") ?? "";
    var videoEmbed = Model?.Value<string>("videoEmbedCode") ?? "";
    var length = (Model?.Value<string>("length") ?? "").Trim();
    var date = Model?.Value<System.DateTime?>("date");
    string dateFormatted = date.HasValue ? date.Value.ToString("M/d/yyyy") : "";

    var crumbs = Model?.AncestorsOrSelf()?.OrderBy(x => x.Level).ToList() ?? new List<IPublishedContent>();

    var related = Model?.Siblings()?
        .Where(x => x.IsPublished()
            && (x.ContentType.Alias == "veterinaryWebinar" || x.ContentType.Alias == "webinar")
            && x.Value<bool?>("active") != false)
        .OrderByDescending(x => x.Value<System.DateTime?>("date") ?? System.DateTime.MinValue)
        .Take(3)
        .ToList() ?? new List<IPublishedContent>();

    string Summary(IPublishedContent c)
    {
        var html = c?.Value<string>("description") ?? "";
        var text = html.StripHtml().Trim();
        return text;
    }
}

<div class="content-wrapper content-webinars content-has-breadcrumb">

    <nav class="breadcrumb-nav">
        @if (crumbs?.Any() == true)
        {
            foreach (var c in crumbs)
            {
                if (c.Id == Model.Id) { continue; }
                <a title="@c.Name" href="@c.Url()">@c.Name</a>
            }
        }
    </nav>

    <header class="ltu-page-hero">
        <p class="ltu-page-hero__eyebrow">Webinar</p>
        <h1 class="ltu-page-hero__title">@title</h1>

        @if (!string.IsNullOrWhiteSpace(length) || !string.IsNullOrWhiteSpace(dateFormatted))
        {
            <div class="ltu-page-hero__meta">
                @if (!string.IsNullOrWhiteSpace(length))
                {
                    <div class="ltu-page-hero__meta-item">
                        <span class="ltu-page-hero__meta-label">Length</span>
                        <span class="ltu-page-hero__meta-value">@length</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(dateFormatted))
                {
                    <div class="ltu-page-hero__meta-item">
                        <span class="ltu-page-hero__meta-label">Original Date</span>
                        <span class="ltu-page-hero__meta-value">@dateFormatted</span>
                    </div>
                }
            </div>
        }
    </header>

    <section class="content-body">
        @if (!string.IsNullOrWhiteSpace(videoEmbed))
        {
            <div class="content-video-player">
                @Html.Raw(videoEmbed)
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(descriptionHtml))
        {
            <article class="ltu-article-body">
                @Html.Raw(descriptionHtml)
            </article>
        }
    </section>

    @if (related.Any())
    {
        <section class="ltu-related">
            <div class="ltu-related__header">
                <p class="ltu-related__kicker">Continue Learning</p>
                <h2 class="ltu-related__title">More Webinars</h2>
            </div>
            <div class="ltu-related__grid">
                @foreach (var w in related)
                {
                    var wTitle = w.Value<string>("title");
                    if (string.IsNullOrWhiteSpace(wTitle)) wTitle = w.Name;
                    <div class="ltu-related__card">
                        <p class="ltu-related__card-section">Webinar</p>
                        <h3 class="ltu-related__card-title"><a href="@w.Url()">@wTitle</a></h3>
                        <p class="ltu-related__card-body">@Summary(w)</p>
                        <div>
                            <a class="ltu-flow-btn ltu-flow-btn--accent" href="@w.Url()">View Webinar</a>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

</div>
