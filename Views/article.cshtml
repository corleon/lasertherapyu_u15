@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@using Clean.Core.Models.ViewModels
@using Clean.Core.Extensions
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core
@using Umbraco.Cms.Core.Models.PublishedContent

@{
    Layout = "master.cshtml";
    var title = Model.Value<string>("title");
    var subtitle = Model.Value<string>("subtitle");
    var mainImage = Model.Value<IPublishedContent>("mainImage");
    var author = Model.Value<IPublishedContent>("author");
    var articleDate = Model.Value<DateTime?>("articleDate");
    var categories = Model.Value<IEnumerable<IPublishedContent>>("categories");
    var contentRows = Model.Value<BlockListModel>("contentRows");
}

@await Html.PartialAsync("~/Views/Partials/pageHeader.cshtml", new PageHeaderViewModel(Model.Name, title, subtitle, mainImage, author?.Name, articleDate, categories))

<article class="content-wrapper content-article ltu-rich-content">
    @Html.GetBlockListHtml(contentRows)
</article>
