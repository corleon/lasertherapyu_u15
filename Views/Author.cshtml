@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@using Clean.Core.Models.ViewModels
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models.PublishedContent

@{
    Layout = "master.cshtml";
    var title = Model.Value<string>("title");
    var subtitle = Model.Value<string>("subtitle");
    var authorListMainImage = Model.Parent?.Value<IPublishedContent>("mainImage");
    var mainImage = Model.Value<IPublishedContent>("mainImage");
    var contentRows = Model.Value<BlockListModel>("contentRows");
}

@await Html.PartialAsync("~/Views/Partials/pageHeader.cshtml", new PageHeaderViewModel(Model.Name, title, subtitle, authorListMainImage, null, null))

<article>
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-md-10 mx-auto">

                <div class="row clearfix">
                    <div class="col-md-4 column mx-auto">
                        <img src="@mainImage?.Url()" alt="@Model.Name" class="w-100">
                        <p class="caption">@Model.Name</p>
                    </div>
                </div>

                @Html.GetBlockListHtml(contentRows)
            </div>
        </div>
    </div>
</article>
